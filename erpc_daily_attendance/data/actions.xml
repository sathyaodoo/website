<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="erpc_create_daily_attendance" model="ir.cron">
        <field name="name">ERPC Create Daily Attendance</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">
employee_ids = model.search([('active', '=', True)])
employee_ids.init_daily_attendance(False)
        </field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="active" eval="True"/>
    </record>

    <record id="erpc_validate_daily_attendance" model="ir.actions.server">
        <field name="name">Validate</field>
        <field name="model_id" ref="model_erpc_hr_daily_attendance"/>
        <field name="binding_model_id" ref="erpc_daily_attendance.model_erpc_hr_daily_attendance"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
records.action_validate()
        </field>
    </record>
</odoo>