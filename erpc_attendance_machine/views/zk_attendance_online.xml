<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="erpc_zk_online_attendance_generate_attendances" model="ir.actions.server">
        <field name="name">Generate Attendances</field>
        <field name="model_id" ref="model_zk_attendance_online"/>
        <field name="binding_model_id" ref="erpc_attendance_machine.model_zk_attendance_online"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            records.generate_zk_online_attendances()
        </field>
    </record>

    <!-- Custom Attendance Form View -->
    <record id="erpc_zk_attendance_online_form" model="ir.ui.view">
        <field name="name">erpc.zk.attendance.online.form</field>
        <field name="model">zk.attendance.online</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="id_employee_device"/>
                    <field name="employee_id"/>
                    <field name="datetime"/>
                    <field name="punch_state"/>
                    <field name="import_state" readonly="True"/>
                    <field name="company_id"/>
                </group>
            </form>
        </field>
    </record>

    <!-- Custom Attendance Tree View -->
    <record id="erpc_zk_attendance_online_tree" model="ir.ui.view">
        <field name="name">erpc.zk.attendance.online.tree</field>
        <field name="model">zk.attendance.online</field>
        <field name="arch" type="xml">
            <list>
                <field name="machine_id" readonly="True"/>
                <field name="id_employee_device"/>
                <field name="employee_id"/>
                <field name="datetime"/>
                <field name="punch_state"/>
                <field name="import_state"/>
            </list>
        </field>
    </record>

    <!-- Action for the Menu Item -->
    <record id="erpc_zk_attendance_online_action" model="ir.actions.act_window">
        <field name="name">ZKTec Online Log</field>
        <field name="res_model">zk.attendance.online</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Item Action Binding -->
  <menuitem id="erpc_zk_attendance_online_menu" name="ZKTec Online Log" parent="erpc_attendance_machine" action="erpc_zk_attendance_online_action" sequence="2"/>
</odoo>
