<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="erpc_biotime_attendance_generate_attendance" model="ir.actions.server">
        <field name="name">Generate Attendance</field>
        <field name="model_id" ref="model_attendance_biotime"/>
        <field name="binding_model_id" ref="erpc_attendance_machine.model_attendance_biotime"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            records.create_biotime_attendance()
        </field>
    </record>

    <!-- Custom Attendance Form View -->
    <record id="view_custom_attendance_form" model="ir.ui.view">
        <field name="name">custom.attendance.form</field>
        <field name="model">attendance.biotime</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="id_employee_device"/>
                    <field name="employee_id"/>
                    <field name="company_id"/>
                    <field name="date"/>
                    <field name="str_time"/>
                    <field name="punch_state"/>
                    <field name="datetime"/>
                    <field name="import_state"/>
                </group>
            </form>
        </field>
    </record>

    <!-- Custom Attendance Tree View -->
    <record id="view_custom_attendance_tree" model="ir.ui.view">
        <field name="name">custom.attendance.tree</field>
        <field name="model">attendance.biotime</field>
        <field name="arch" type="xml">
            <list>
                <field name="id_employee_device"/>
                <field name="employee_id"/>
                <field name="date"/>
                <field name="str_time"/>
                <field name="punch_state"/>
                <field name="datetime"/>
                <field name="import_state"/>
            </list>
        </field>
    </record>

    <!-- Menu Item under Human Resources -->
    <menuitem id="erpc_attendance_machine" name="Attendance Machine" parent="hr_attendance.menu_hr_attendance_root"/>

    <!-- Action for the Menu Item -->
    <record id="erpc_attendance_biotime_action" model="ir.actions.act_window">
        <field name="name">BioTime Log</field>
        <field name="res_model">attendance.biotime</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Item Action Binding -->
    <menuitem id="erpc_attendance_biotime_menu" name="BioTime Log" parent="erpc_attendance_machine" action="erpc_attendance_biotime_action" sequence="4"/>
</odoo>
