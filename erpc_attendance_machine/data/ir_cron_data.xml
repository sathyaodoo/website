<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="erpc_zk_machine_get_attendances" model="ir.cron">
            <field name="name">ERPC: Auto Get Attendances</field>
            <field name="model_id" ref="model_zk_machine"/>
            <field name="type">ir.actions.server</field>
            <field name="state">code</field>
            <field name="code">
machine_ids = env['zk.machine'].search([])
machine_ids.get_attendances()
            </field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="nextcall" eval="(datetime.now()).strftime('%Y-%m-%d 21:00:00')"/>
<!--            <field name="numbercall">-1</field>-->
        </record>
    </data>
</odoo>
