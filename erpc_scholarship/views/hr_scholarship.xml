<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="hr_scholarship_tree_view" model="ir.ui.view">
        <field name="name">hr.scholarship.tree</field>
        <field name="model">hr.scholarship</field>
        <field name="arch" type="xml">
            <list string="Scholarship">
                <field name="name"/>
                <field name="employee_id" readonly="paid == True"/>
                <field name="scholarship_amount" readonly="paid == True"/>
                <field name="batch_id"/>
                <field name="paid" readonly="1"/>
                <field name="date"/>
            </list>
        </field>
    </record>

    <record id="hr_scholarship_form_view" model="ir.ui.view">
        <field name="name">hr.scholarship.form</field>
        <field name="model">hr.scholarship</field>
        <field name="arch" type="xml">
            <form string="Scholarship">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group col="4">
                        <field name="employee_id" readonly="paid == True"/>
                        <field name="date" readonly="paid == True"/>
                        <field name="department_id"/>
                        <field name="job_position"/>
                        <field name="scholarship_amount" readonly="paid == True"/>
                        <field name="payslip_id" invisible="1"/>
                        <field name="batch_id"/>
                        <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                        <field name="currency_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                        <field name="paid" readonly="1" invisible="1"/>
                        <field name="note"/>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="view_scholarship_request_search_form" model="ir.ui.view">
        <field name="name">hr.scholarship.search.form</field>
        <field name="model">hr.scholarship</field>
        <field name="arch" type="xml">
            <search string="Scholarship">
                <field name="employee_id" string="Employee"/>
                <field name="department_id" string="Department"/>
                <field name="batch_id" string="Payslip Batch"/>
                <filter string="Payslip Batch" name="batch_id" context="{'group_by':'batch_id'}"/>
                <filter string="Employee" name="employee_id" context="{'group_by':'employee_id'}"/>
                <filter string="Department" name="department_id" context="{'group_by':'department_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_hr_scholarship_request" model="ir.actions.act_window">
        <field name="name">Scholarship</field>
        <field name="res_model">hr.scholarship</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_myrequest': 1}</field>
        <field name="search_view_id" ref="view_scholarship_request_search_form"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new scholarship.
            </p>
            <p>
                Use this menu to create scholarship.
            </p>
        </field>
    </record>

    <menuitem name="Scholarship" parent="erpc_hr_payroll_extension.menu_hr_allowances" id="menu_hr_scholarship" action="action_hr_scholarship_request" sequence="5"/>

    <record id="act_hr_employee_scholarship_request" model="ir.actions.act_window">
        <field name="name">Scholarship</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hr.scholarship</field>
        <field name="binding_model_id" ref="hr.model_hr_employee"/>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="hr_scholarship_tree_view"/>
        <field name="domain">[('employee_id', '=', active_id)]</field>

    </record>
</odoo>
