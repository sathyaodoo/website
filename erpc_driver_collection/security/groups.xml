<odoo>
    <data>

        <record model="ir.module.category" id="driver_collection_category">
            <field name="name">Cash Collection</field>

        </record>
        <record model="res.groups.privilege" id="res_groups_privilege_driver_collection_category">
            <field name="name">Cash Collection</field>
            <field name="category_id" ref="erpc_driver_collection.driver_collection_category"/>
        </record>

        <record id='group_user_driver' model='res.groups'>
            <field name='name'>
                User: Own documents
            </field>
            <field name="privilege_id" ref="erpc_driver_collection.res_groups_privilege_driver_collection_category"/>
        </record>

        <record id='group_all_client_user_driver' model='res.groups'>
            <field name='name'>
                User All Clients
            </field>
            <field name="privilege_id" ref="erpc_driver_collection.res_groups_privilege_driver_collection_category"/>
            <field name="implied_ids" eval="[(4, ref('erpc_driver_collection.group_user_driver'))]"/>
        </record>

        <record id='group_admin_driver' model='res.groups'>
            <field name='name'>
                Administrator
            </field>
            <field name="privilege_id" ref="erpc_driver_collection.res_groups_privilege_driver_collection_category"/>
            <field name="implied_ids" eval="[(4, ref('erpc_driver_collection.group_all_client_user_driver'))]"/>
        </record>

        <record id='group_is_created_driver' model='res.groups'>
            <field name='name'>
                Driver
            </field>
        </record>

        <record id="group_see_only_all_cash" model="res.groups">
            <field name="name">
                See All Cash Documents
            </field>
        </record>

        <record id="see_all_documents_record_rule" model="ir.rule">
            <field name="name">Product Collection: User (only see all document)</field>
            <field name="model_id" ref="model_product_driver"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('erpc_driver_collection.group_see_only_all_cash'))]"/>
            <field name="active" eval="True"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="user_collection_record_rule" model="ir.rule">
            <field name="name">Product Collection: User</field>
            <field name="model_id" ref="model_product_driver"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('erpc_driver_collection.group_user_driver'))]"/>
            <field name="active" eval="True"/>
        </record>

        <record id="admin_collection_record_rule" model="ir.rule">
            <field name="name">Product Collection: Admin</field>
            <field name="model_id" ref="model_product_driver"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups"
                   eval="[(4, ref('erpc_driver_collection.group_admin_driver')), (4, ref('erpc_driver_collection.group_all_client_user_driver'))]"/>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
