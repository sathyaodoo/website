<odoo>
    <data>
        <!-- Scheduled action for timeoff reminder -->
        <record id="ir_cron_send_timeoff_reminder" model="ir.cron">
            <field name="name">ERPC: Send Time-Off Reminder</field>
            <field name="model_id" ref="model_hr_attendance_reminder"/>
            <field name="state">code</field>
            <field name="code">model.send_timeoff_reminder()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(datetime.now() + relativedelta(hour=5, minute=30)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">100</field>
        </record>

        <!-- Scheduled action for check-in reminder -->
        <record id="ir_cron_send_check_in_reminder" model="ir.cron">
            <field name="name">ERPC: Send Check-In Reminder</field>
            <field name="model_id" ref="model_hr_attendance_reminder"/>
            <field name="state">code</field>
            <field name="code">model.send_check_in_reminder()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(datetime.now() + relativedelta(hour=5, minute=30)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">100</field>
        </record>

        <!-- Scheduled action for check-out reminder -->
        <record id="ir_cron_send_check_out_reminder" model="ir.cron">
            <field name="name">ERPC: Send Check-Out Reminder</field>
            <field name="model_id" ref="model_hr_attendance_reminder"/>
            <field name="state">code</field>
            <field name="code">model.send_check_out_reminder()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(datetime.now() + relativedelta(hour=20, minute=0)).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="priority">100</field>
        </record>
    </data>
</odoo>
