<?xml version="1.0" encoding="utf-8"?>
<odoo>
   <data noupdate="1">
       <!-- <record model="ir.module.category" id="request_for_advance_category">
           <field name="name">Request for Advance</field>
       </record> -->

      <record model="res.groups.privilege" id="res_group_privilege_advance_requester_category">
            <field name="name">Request for Advance</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
      </record>

       <record id="group_advance_requester" model="res.groups">
            <field name="name">Advance Requester</field>
            <field name="privilege_id" ref="erpc_hr_request_for_advance_menu_item.res_group_privilege_advance_requester_category"/>
      </record>

       <record id="group_advance_hr" model="res.groups">
           <field name="name">HR</field>
           <field name="privilege_id" ref="erpc_hr_request_for_advance_menu_item.res_group_privilege_advance_requester_category"/>
           <field name="implied_ids" eval="[(4, ref('erpc_hr_request_for_advance_menu_item.group_advance_requester'))]"/>
       </record>

       <record id="group_advance_manager" model="res.groups">
           <field name="name">Manager</field>
           <field name="privilege_id" ref="erpc_hr_request_for_advance_menu_item.res_group_privilege_advance_requester_category"/>
           <field name="implied_ids" eval="[(4, ref('erpc_hr_request_for_advance_menu_item.group_advance_requester'))]"/>
       </record>

       <!-- Access Rules (unchanged) -->
       <record id="hr_advance_request_requester_rule" model="ir.rule">
           <field name="name">Advance Requester: Only own requests</field>
           <field name="model_id" ref="model_hr_advance_request"/>
           <field name="domain_force">[('create_uid','=', user.id)]</field>
           <field name="groups" eval="[(4, ref('group_advance_requester'))]"/>
       </record>

       <record id="hr_advance_request_hr_rule" model="ir.rule">
           <field name="name">HR: See all requests</field>
           <field name="model_id" ref="model_hr_advance_request"/>
           <field name="domain_force">[(1, '=', 1)]</field>
           <field name="groups" eval="[(4, ref('group_advance_hr'))]"/>
       </record>

       <record id="hr_advance_request_manager_rule" model="ir.rule">
           <field name="name">Manager: See all requests</field>
           <field name="model_id" ref="model_hr_advance_request"/>
           <field name="domain_force">[(1, '=', 1)]</field>
           <field name="groups" eval="[(4, ref('group_advance_manager'))]"/>
       </record>
   </data>
</odoo>
   