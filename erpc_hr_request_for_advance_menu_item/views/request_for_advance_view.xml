<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_advance_request_tree_view" model="ir.ui.view">
        <field name="name">hr.advance.request.tree</field>
        <field name="model">hr.advance.request</field>
        <field name="arch" type="xml">
            <list string="Advance Requests">
                <field name="create_date" optional="show"/>
                <field name="payment_start_date" optional="show"/>
                <field name="employee_id" optional="show"/>
                <field name="advancement_type" optional="show"/>
                <field name="total_amount" optional="show"/>
                <field name="total_paid_amount" optional="show"/>
                <field name="balance_amount" optional="show"/>
                <field name="request_reason" optional="show"/>
                <field name="reason" optional="show"/>
                <field name="state" optional="show"/>
                <field name="advance_state" string="Advance State" widget="badge"
                       decoration-danger="advance_state == 'refused'"
                       decoration-warning="advance_state == 'partially_closed'"
                       decoration-success="advance_state == 'closed'"
                       invisible="advance_state not in ('partially_closed', 'closed', 'refused')" optional="show"/>
            </list>
        </field>
    </record>

    <record id="hr_advance_request_form_view" model="ir.ui.view">
        <field name="name">hr.advance.request.form</field>
        <field name="model">hr.advance.request</field>
        <field name="arch" type="xml">
            <form string="Advance Request">
                <field name="payment_start_date_readonly" invisible="1"/>
                <field name="is_balanced" invisible="1"/>
                <field name="is_advance_requester" invisible="1"/>
                <field name="is_hr_advance" invisible="1"/>
                <field name="is_manager_advance" invisible="1"/>
                <field name="can_edit_line" invisible="1"/>
                <header>
                    <field name="amount_mismatch" invisible="1"/>
                    <button class="oe_highlight" invisible="state not in ['draft']" name="action_submit" string="Submit"
                            type="object"/>
                    <button class="oe_highlight" groups="hr.group_hr_manager"
                            invisible="state not in ['waiting_approval_1'] or not is_hr_advance" name="action_approve"
                            string="Approve" type="object"/>
                    <button class="oe_highlight" groups="hr.group_hr_manager"
                            invisible="state != 'waiting_approval_1' or not is_hr_advance" name="action_refuse"
                            string="Refuse" type="object"/>
                    <button class="oe_highlight" invisible="state not in ['waiting_approval_1', 'approve']"
                            name="action_set_to_draft" string="Set to Draft" type="object"/>
                    <button class="oe_highlight" name="action_compute_installment" string="Compute Installment"
                            type="object" invisible="state in ['partially_closed', 'closed']"/>
                    <field name="state"
                           statusbar_visible="draft,waiting_approval_1,approve,paid,partially_closed,closed,refused"
                           widget="statusbar"/>
                </header>
                <div class="alert alert-warning oe_edit_only"
                     role="alert"
                     invisible="not amount_mismatch">
                    Total of installments
                    <field name="total_amount" readonly="1"/>
                    is different from Amount.
                    You can fix it by editing the lines or using Compute Installment.
                </div>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                    </div>

                    <widget name="web_ribbon" title="Closed" bg_color="text-bg-success"
                            invisible="advance_state != 'closed'"/>
                    <widget name="web_ribbon" title="Partially Closed" bg_color="text-bg-warning"
                            invisible="advance_state != 'partially_closed'"/>
                    <widget name="web_ribbon" title="Refused" bg_color="text-bg-danger"
                            invisible="advance_state != 'refused'"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group col="6">
                            <field name="advance_state" invisible="1" force_save="1"/>
                            <field name="employee_id"
                                   domain="[('user_id', '=', uid)]"
                                   invisible="is_hr_advance" required="is_advance_requester == True"
                                   readonly="state not in ('draft', 'waiting_approval_1') or (state != 'draft' and is_advance_requester and not is_hr_advance)"/>
                            <field name="employee_id"
                                   invisible="not is_hr_advance" required="not is_advance_requester"
                                   readonly="state not in ('draft', 'waiting_approval_1') or (state != 'draft' and is_advance_requester and not is_hr_advance)"/>

                            <field name="advancement_type"
                                   readonly="(state != 'draft' and is_advance_requester and not is_hr_advance) or state not in ('draft', 'waiting_approval_1')"/>
                            <field name="amount"/>
                            <field name="number_of_instalments"
                                   readonly="advancement_type == 'short' or (state != 'draft' and is_advance_requester and not is_hr_advance)"/>
                            <field name="create_date"/>
                        </group>
                        <group col="6">

                            <field name="payment_start_date"
                                   readonly="state not in ('draft', 'waiting_approval_1') or payment_start_date_readonly or (state != 'draft' and is_advance_requester and not is_hr_advance)"/>
                            <field name="company_id" options="{'no_create': True, 'no_open': True}" readonly="1"
                                   invisible="1"/>
                            <field name="currency_id" options="{'no_create': True, 'no_open': True}"
                                   readonly="(state != 'draft' and is_advance_requester and not is_hr_advance) or state not in ('draft', 'waiting_approval_1')"/>
                            <field name="request_reason" style="width: 200px;"
                                   readonly="(state != 'draft' and is_advance_requester and not is_hr_advance) or state not in ('draft', 'waiting_approval_1')"/>

                            <field name="reason" invisible="state != 'refused'" readonly="1"/>

                        </group>
                    </group>
                    <notebook>
                        <page string="Installments">
                            <field name="advance_lines" readonly="state == 'closed'">
                                <list editable="bottom" string="Installments">
                                    <field name="payment_date" readonly="paid"/>
                                    <field name="amount" readonly="paid"/>
                                    <field name="paid" column_invisible="1" readonly="1"/>
                                    <field name="payslip_name" column_invisible="1" readonly="1"/>
                                    <field name="payslip_reference" readonly="1"/>
                                    <field name="batch_name" readonly="1"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right" colspan="2">
                                <field name="total_amount" options="{'currency_field': 'currency_id'}"
                                       widget="monetary"/>
                                <field name="total_paid_amount" options="{'currency_field': 'currency_id'}"
                                       widget="monetary"/>
                                <field class="oe_subtotal_footer_separator" name="balance_amount"
                                       options="{'currency_field': 'currency_id'}" widget="monetary"/>
                            </group>
                            <div class="oe_clear"/>
                        </page>
                    </notebook>

                </sheet>
                <!-- Chatter -->
                <chatter>
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </chatter>
            </form>
        </field>
    </record>
    <record id="view_hr_advance_request_search_form" model="ir.ui.view">
        <field name="name">hr.advance.request.search.form</field>
        <field name="model">hr.advance.request</field>
        <field name="arch" type="xml">
            <search string="Advance Request">
                <field name="employee_id" string="Employee"/>
                <filter context="{'group_by':'employee_id'}" name="employee_id" string="Employee"/>
                <filter context="{'group_by':'state'}" name="status" string="Status"/>
            </search>
        </field>
    </record>
    <!--loan menu-->
    <record id="action_hr_advance_request" model="ir.actions.act_window">
        <field name="name">Request For Advance</field>
        <field name="res_model">hr.advance.request</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_myrequest': 1}</field>
        <field name="search_view_id" ref="view_hr_advance_request_search_form"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new Advance request.
            </p>
            <p>
                Use this menu to create Advance requests.
            </p>
        </field>
    </record>
<!--    <menuitem id="erpc_hr_payroll_extension.menu_hr_deductions" name="Deductions"-->
<!--              groups="hr_payroll.group_hr_payroll_manager,erpc_hr_request_for_advance_menu_item.group_advance_requester"/>-->
    <menuitem action="action_hr_advance_request" id="menu_hr_advance_request" name="Request For Advance"
              parent="erpc_hr_payroll_extension.menu_hr_deductions" groups="group_advance_requester"/>
</odoo>