<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="erpc_view_hr_payslip_form" model="ir.ui.view">
        <field name="name">erpc.hr.payslip</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_payslip_cancel']" position="attributes">
                <attribute name="invisible">state in ['paid', 'done']</attribute>
            </xpath>
            <xpath expr="//button[@name='refund_sheet'][1]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='refund_sheet'][2]" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>
</odoo>