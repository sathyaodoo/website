<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_sale_order_form_erpc_ware" model="ir.ui.view">
            <field name="name">sale.order.form.erpc.ware</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale_stock.view_order_form_inherit_sale_stock"/>
            <field name="arch" type="xml">

                <xpath expr="/form/sheet/notebook/page[@name='other_information']/group/group[@name='sale_shipping']/field[@name='warehouse_id']" position="after">
                    <field invisible="1" name="user_in_sales_group"/>
                </xpath>

                <xpath expr="/form/sheet/notebook/page[@name='other_information']/group/group[@name='sale_shipping']/field[@name='warehouse_id']" position="attributes">
                    <attribute name="readonly">user_in_sales_group == False or state in ('sale', 'done')</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
