<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="rule_hr_bonus" model="ir.rule">
            <field name="name">Bonus Request Multi Company</field>
            <field name="model_id" ref="model_hr_bonus"/>
            <field eval="True" name="global"/>
            <field name="domain_force">['|',('company_id','=',False),('company_id','child_of',[user.company_id.id])]</field>
        </record>

        <record id="hr_bonus_manager_rule" model="ir.rule">
            <field name="name">Bonus Modification Accounts and Hr</field>
            <field name="model_id" ref="model_hr_bonus"/>
            <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>