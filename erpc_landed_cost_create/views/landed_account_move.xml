<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="inherited_landed_costs_view_form" model="ir.ui.view">
            <field name="name">inherited.landed.costs.form.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">

                <xpath expr="//form[1]/header[1]/t[1]" position="replace">
                    <t groups="stock.group_stock_manager, erpc_landed_cost_create.group_landed_cost_button">
                        <field name="landed_costs_visible" invisible="1"/>
                        <button name="button_create_landed_costs" class="oe_highlight" string="Create Landed Costs"
                                data-hotkey="l" type="object" groups="account.group_account_invoice"
                                invisible="not landed_costs_visible"/>

                    </t>
                </xpath>

                <xpath expr="//form[1]/sheet[1]/div[@name='button_box']/t[1]" position="replace">
                    <t groups="stock.group_stock_manager, erpc_landed_cost_create.group_landed_cost_button">
                        <field name="landed_costs_ids" invisible="1"/>
                        <button string="Landed Costs" type="object" name="action_view_landed_costs"
                                class="oe_stat_button" icon="fa-plus-square" invisible="not landed_costs_ids"/>

                    </t>
                </xpath>


                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='invoice_tab']/field[@name='invoice_line_ids']/tree[1]/field[@name='product_type']"
                       position="attributes">
                    <attribute name="groups">stock.group_stock_manager,erpc_landed_cost_create.group_landed_cost_button
                    </attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='invoice_tab']/field[@name='invoice_line_ids']/tree[1]/field[@name='is_landed_costs_line']"
                       position="attributes">
                    <attribute name="groups">stock.group_stock_manager,erpc_landed_cost_create.group_landed_cost_button
                    </attribute>
                </xpath>


            </field>
        </record>

        <record id='inherit_view_entry_stock_landed_cost_form' model='ir.ui.view'>
            <field name="name">entry.stock.landed.cost.form</field>
            <field name="model">stock.landed.cost</field>
            <field name="inherit_id" ref="stock_landed_costs.view_stock_landed_cost_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='target_model']" position="attributes">
                    <attribute name="groups">stock.group_stock_manager,erpc_landed_cost_create.group_landed_cost_button
                    </attribute>
                </xpath>

                <!--                <xpath expr="//field[@name='mrp_production_ids']" position="attributes">-->
                <!--                    <attribute name="groups">stock.group_stock_manager,erpc_landed_cost_create.group_landed_cost-->
                <!--                    </attribute>-->
                <!--                </xpath>-->
            </field>
        </record>


    </data>
</odoo>
