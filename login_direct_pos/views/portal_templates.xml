<template id="as_shop_mini_cart" name="Mini Cart Extend" inherit_id="website_sale.header_cart_link" priority="1">
        <xpath expr="//a[@href='/shop/cart']" position="attributes">
            <attribute name="t-attf-class" separator=" " add="as_mini_cart"/>
        </xpath>
        <xpath expr="//sup[contains(@t-attf-class,'my_cart_quantity')]" position="attributes">
            <attribute name="t-attf-class" separator=" " remove="#{'d-none' if (website_sale_cart_quantity == 0) else ''}"/>
        </xpath>
    </template>

<template id="custom_step_wizard" inherit_id="website.step_wizard">
  
    <!-- Replace the main wizard div -->
    <xpath expr="//div[contains(@class,'o_wizard')]" position="replace">
          <style>
        .o_wizard {
    width: 100%;
    gap: 5px;
}

.wizard-tab {
    flex: 1;
    padding: 15px 10px;
    min-height: 50px;
    text-align: center;
    transition: all 0.3s ease;
}

.inactive-step {
    background-color: #1a1a1a !important;
    color: #ffffff !important;
}

.active-step {
    background-color: #ffffff !important;
    color: #e60000 !important;
    border: 1px solid #dee2e6;
    border-bottom: 3px solid #e60000 !important;
    position: relative;
    z-index: 10;
}

.wizard-tab span {
    font-size: 0.9rem;
    letter-spacing: 1px;
}
    </style>
        <div class="o_wizard d-flex justify-content-center my-4">
            <t t-foreach="wizard_step" t-as="step">
                
                <t t-set="is_current_step"
                   t-value="step.step_href == current_website_checkout_step_href"/>

                <div t-attf-class="wizard-tab d-flex align-items-center justify-content-center #{'active-step' if is_current_step else 'inactive-step'}">
                    
                    <span t-if="is_current_step or not_completed_step"
                          class="text-uppercase fw-bold">
                        <span t-field="step.name"/>
                    </span>

                    <a t-else=""
                       t-att-href="step.step_href"
                       class="text-decoration-none text-uppercase fw-bold text-white">
                        <span t-field="step.name"/>
                    </a>

                </div>

                <!-- Mark steps after current as not clickable -->
                <t t-if="is_current_step"
                   t-set="not_completed_step"
                   t-value="True"/>
            </t>
        </div>

    </xpath>

</template>


</odoo>