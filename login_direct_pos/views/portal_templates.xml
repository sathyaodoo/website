    <template id="my_account_link_new" name="New Link to frontend portal" inherit_id="portal.user_dropdown">
    <xpath expr="//*[@id='o_logout_divider']" position="before">
        
        <a href="/my/account" role="menuitem" class="dropdown-item ps-3">
            <i class="fa fa-fw fa-user me-1 small text-primary-emphasis"/>
            Edit Account
        </a>

        <a href="/my/orders" role="menuitem" class="dropdown-item ps-3">
            <i class="fa fa-fw fa-shopping-bag me-1 small text-primary-emphasis"/>
            Orders History
        </a>

        <a href="/my/addresses" role="menuitem" class="dropdown-item ps-3">
            <i class="fa fa-fw fa-address-book me-1 small text-primary-emphasis"/>
            Address Book
        </a>

        <a href="/shop/wishlist" role="menuitem" class="dropdown-item ps-3">
            <i class="fa fa-fw fa-heart me-1 small text-primary-emphasis"/>
            My Wishlist
        </a>

    </xpath>
</template>

       <template id="portal_top_navigation">
           <style>.portal-custom-header {
    background-color: #111;
    padding: 15px 0;
}

.portal-menu {
    gap: 40px;
    padding-left: 40px;
}

.portal-menu .menu-item {
    color: #ffffff;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
}

.portal-menu .menu-item:hover {
    color: #e60000;
}

.portal-menu .menu-item.active {
    color: #e60000;
    text-decoration: underline;
}

.portal-menu .logout {
    margin-left: auto;
    padding-right: 40px;
}
</style>
    <t t-set="current_path" t-value="request.httprequest.path"/>

    <!-- Only show for selected pages -->
    <t t-if="
        current_path.startswith('/my/account') or
        current_path.startswith('/my/orders') or
        current_path.startswith('/my/addresses') or
        current_path.startswith('/shop/wishlist')
    ">

        <div class="portal-custom-header">
            <div class="container-fluid">
                <div class="portal-menu d-flex align-items-center">

                    <!-- Edit Account -->
                    <a href="/my/account"
                       t-att-class="'menu-item active' if current_path.startswith('/my/account') else 'menu-item'">
                        EDIT ACCOUNT
                    </a>

                    <!-- Orders -->
                    <a href="/my/orders"
                       t-att-class="'menu-item active' if current_path.startswith('/my/orders') else 'menu-item'">
                        ORDERS HISTORY
                    </a>

                    <!-- Address -->
                    <a href="/my/addresses"
                       t-att-class="'menu-item active' if current_path.startswith('/my/addresses') else 'menu-item'">
                        ADDRESS BOOK
                    </a>

                    <!-- Wishlist -->
                    <a href="/shop/wishlist"
                       t-att-class="'menu-item active' if current_path.startswith('/shop/wishlist') else 'menu-item'">
                        MY WISHLIST
                    </a>

                    <!-- Logout -->
                    <a href="/web/session/logout"
                       class="menu-item logout ms-auto">
                        LOGOUT
                    </a>

                </div>
            </div>
        </div>

    </t>
</template>



    <!-- ======================================
         Inject Header Into All Portal Pages
    ======================================= -->
    <template id="portal_layout_inherit"
              inherit_id="portal.portal_layout">

        <xpath expr="//div[contains(@class,'o_portal_wrap')]" position="before">
            <t t-call="login_direct_pos.portal_top_navigation"/>
        </xpath>

    </template>

   

