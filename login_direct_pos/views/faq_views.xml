<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FAQ Tree View -->
    <record id="faq_view_tree" model="ir.ui.view">
        <field name="name">faq.tree</field>
        <field name="model">faq.model</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- FAQ Form View -->
    <record id="faq_view_form" model="ir.ui.view">
        <field name="name">faq.form</field>
        <field name="model">faq.model</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>

                    <notebook>
                        <page string="FAQ">
                            <field name="faq_line_ids">
                                <form>
                                    <group>
                                        <group>
                                             <field name="question"/>
                                    <field name="answer"/>
                                        </group>
                                    </group>
                                </form>
                                <list>
                                    <field name="question"/>
                                    <field name="answer"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="faq_action" model="ir.actions.act_window">
        <field name="name">FAQ</field>
        <field name="res_model">faq.model</field>
        <field name="view_mode">list,form</field>
        <field name="type">ir.actions.act_window</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_faq"
              name="FAQ"
              parent="website.menu_website_global_configuration"
              action="faq_action"/>
              
</odoo>