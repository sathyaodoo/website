    <template id="custom_shop_layout" inherit_id="website_sale.products" name="Custom Shop Layout">
        
        <xpath expr="//div[@id='wrap']" position="inside">
            <style>
                .custom_shop_banner {
                    background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/web/image/website.s_banner_default_image');
                    background-size: cover;
                    background-position: center;
                    padding: 80px 0;
                    margin-bottom: 2rem;
                }
                .sidebar_search .input-group {
                    border: 1px solid #ddd;
                    border-radius: 0px;
                }
                .sidebar_search .btn-danger {
                    background-color: #e30613; /* Tire shop red */
                    border: none;
                }
            </style>
        </xpath>

        <xpath expr="//div[@id='o_wsale_container']" position="before">
            <div class="custom_shop_banner text-center text-white">
                <div class="container">
                    <h1 class="display-4 fw-bold text-uppercase">
                        <t t-if="category" t-out="category.name"/>
                        <t t-else="">All Products</t>
                    </h1>
                </div>
            </div>
        </xpath>

        <xpath expr="//aside[@id='products_grid_before']/*[1]" position="before">
            <div class="sidebar_search mb-4">
                <h6 class="fw-bold text-uppercase mb-2">Search</h6>
                <form method="get" action="/shop" class="input-group">
                    <input type="text" name="search" class="form-control border-0 bg-light" placeholder="Search products..." t-att-value="search"/>
                    <button type="submit" class="btn btn-danger">
                        <i class="oi oi-search"/>
                    </button>
                </form>
            </div>
        </xpath>

        <xpath expr="//header[@id='o_wsale_products_header']" position="attributes">
            <attribute name="class" add="d-none" separator=" "/>
        </xpath>

    </template>

  

</odoo>


    