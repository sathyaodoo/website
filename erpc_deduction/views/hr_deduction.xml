<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--Deduction Tree view-->
    <record id="hr_deduction_tree_view" model="ir.ui.view">
        <field name="name">hr.deduction.tree</field>
        <field name="model">hr.deduction</field>
        <field name="arch" type="xml">
            <list string="Deduction">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="deduction_amount"/>
                <field name="date"/>
            </list>
        </field>
    </record>

    <!--Deduction Form view-->
    <record id="hr_deduction_form_view" model="ir.ui.view">
        <field name="name">hr.deduction.form</field>
        <field name="model">hr.deduction</field>
        <field name="arch" type="xml">
            <form string="Deduction">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group col="4">
                        <field name="employee_id"/>
                        <field name="date"/>
                        <field name="department_id"/>
                        <field name="job_position"/>
                        <field name="deduction_amount"/>
                        <field name="date"/>
                        <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                        <field name="currency_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                        <field name="paid" readonly="1"/>
                        <field name="note"/>

                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <!--deduction  search view-->
    <record id="view_deduction_request_search_form" model="ir.ui.view">
        <field name="name">hr.deduction.search.form</field>
        <field name="model">hr.deduction</field>
        <field name="arch" type="xml">
            <search string="Deduction">
                <field name="employee_id" string="Employee"/>
                <field name="department_id" string="Department"/>
                <filter string="Employee" name="employee_id" context="{'group_by':'employee_id'}"/>
                <filter string="Department" name="department_id" context="{'group_by':'department_id'}"/>
            </search>
        </field>
    </record>


    <!--deduction  menu-->
    <record id="action_hr_deduction_request" model="ir.actions.act_window">
        <field name="name">Deduction</field>
        <field name="res_model">hr.deduction</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_myrequest': 1}</field>
        <field name="search_view_id" ref="view_deduction_request_search_form"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new deduction.
            </p>
            <p>
                Use this menu to create deduction.
            </p>
        </field>
    </record>

    <menuitem name="Deduction" parent="erpc_hr_payroll_extension.menu_hr_deductions" id="menu_hr_deduction"
              action="action_hr_deduction_request"/>

    <!-- Shortcuts -->
    <record id="act_hr_employee_deduction_request" model="ir.actions.act_window">
        <field name="name">Deduction</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hr.deduction</field>
        <field name="binding_model_id" ref="hr.model_hr_employee"/>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="hr_deduction_tree_view"/>
        <field name="domain">[('employee_id', '=', active_id)]</field>


    </record>

    <!-- HR employee inherit deduction -->
    <record id="view_employee_form_insurance_inherit" model="ir.ui.view">
        <field name="name">hr.employee.company.deduction.form.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority" eval="1000"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(act_hr_employee_deduction_request)d" type="action" class="oe_stat_button"
                        icon="fa-minus-square-o" groups="hr.group_hr_manager,hr.group_hr_user">
                    <field name="deduction_count" widget="statinfo" string="Deduction"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
