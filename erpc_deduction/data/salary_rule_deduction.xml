<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="hr_rule_deduction" model="hr.salary.rule">
            <field name="code">DED</field>
            <field name="name">Deduction</field>
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="condition_select">python</field>
            <field name="condition_python">result = 'DED' in inputs</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = inputs['DED'] and - inputs['DED'].amount</field>
            <field name="appears_on_payslip" eval="True"/>
            <field name="sequence" eval="12"/>
            <field name="struct_id" ref="erpc_hr_payroll_extension.erpc_structure"/>
        </record>

        <record id="hr_rule_input_deduction" model="hr.payslip.input.type">
            <field name="code">DED</field>
            <field name="name">Deduction</field>
        </record>
    </data>
</odoo>
