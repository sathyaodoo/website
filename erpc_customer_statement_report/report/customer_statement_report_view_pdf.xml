<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>

		<template id="partnerledger">
			<t t-call="web.html_container">
				<t t-foreach="docs" t-as="o">
					<t t-call="web.external_layout">
						<div class="page">

							<h2>Statement Of Account</h2>

							<div class="row">
                                <div class="col-3">
									<strong>Partner:</strong>
									<p t-esc="o.name" />
								</div>
								<div class="col-3">
								</div>

<!--                                 <div class="col-3">
									<t t-if="data['form']['currency_id']">
										<strong>Currency :</strong>
										<p t-esc="data['form']['currency_id'][1]"/>
										<br />
									</t>
								</div> -->
<!-- 								<div class="col-3">
									<strong>Company:</strong>
									<p t-esc="res_company.name" />
								</div>
								<div class="col-3">
									<strong>Partner:</strong>
									<p t-esc="o.name" />
								</div> -->
<!-- 								<div class="col-3">
									<strong>Target Moves:</strong>
									<p t-if="data['form']['target_move'] == 'all'">All Entries</p>
									<p t-if="data['form']['target_move'] == 'posted'">All Posted Entries</p>
								</div> -->
<!--								<div class="col-3"-->
<!--									t-if="data['form']['date_from'] or data['form']['date_to']">-->
<!--									<t t-if="data['form']['date_from']">-->
<!--										<strong>Date from :</strong>-->
<!--										<span t-esc="data['form']['date_from']" />-->
<!--										<br />-->
<!--									</t>-->
<!--									<t t-if="data['form']['date_to']">-->
<!--										<strong>Date to :</strong>-->
<!--										<span t-esc="data['form']['date_to']" />-->
<!--									</t>-->
<!--								</div>-->
							</div>
							<br/>
							<br/>
							<t t-foreach="get_lines(data,o)" t-as="cu">

								<h3 t-esc="cu['cu'].name" />

								<table
									class="table  table-bordered table-striped table-hover">
									<thead>
										<tr>
											<th>Date</th>
<!-- 											<th>JRNL</th> -->
											<th>Ref</th>
											<th>Debit</th>
											<th class="text-right">Credit</th>
											<th t-if="not data['form']['with_null_amount_residual']" class="text-right">Amount Due</th>
											<th t-if="data['form']['with_null_amount_residual']">Balance</th>
										</tr>
									</thead>
									<tbody>
										<t t-set="total" t-value="{'d':0.0,'c':0.0, 'r':0.0}" />
										<t>
											<tr
												t-if="data['form']['with_initial_balance']">

												<td />
												<td>Initial Balance</td>
												<td style="text-align:right !important"
													t-esc="cu['bal']['debit']"
													t-options="{'widget': 'monetary', 'display_currency': cu['cu']}" />
												<td style="text-align:right !important"

													t-esc="cu['bal']['credit']"
													t-options="{'widget': 'monetary', 'display_currency': cu['cu']}" />
												<td style="text-align:right !important"

													t-esc="cu['bal']['debit'] - cu['bal']['credit']"
													t-options="{'widget': 'monetary', 'display_currency': cu['cu']}" />
												<t t-set="total"
													t-value="{'d':total['d']+cu['bal']['debit'],'c':total['c']+cu['bal']['credit'], 'r':total['r']}" />
											</tr>

											<t t-if="data['form']['with_initial_balance']" t-set="bal"
												t-value="cu['bal']['debit'] - cu['bal']['credit']" />
											<t t-else="" t-set="bal" t-value="0.0" />

											<tr
												t-foreach="cu['lines']" t-as="line" t-if="line['date']">
												<td style="white-space:nowrap">
													<span style="padding:10.0px"><span t-esc="line['date']"/></span>
												</td>
<!-- 												<td>
													<span style="padding:8.0px"><span t-esc="line['code']" /></span>
												</td> -->
												<td>
													<span t-esc="line['jname']"/>
                                                    <br/>
													<t t-if="line['ref']">
<!-- 														- -->
<!-- 														<span style="padding:50.0px;white-space:nowrap"><span t-esc="line['ref']"/></span> -->
                                                        <span style="white-space:nowrap"><span t-esc="line['ref']"/></span>
													</t>
<!-- 													<t t-if="line['name']">
														-
														<span style="padding:50.0px"><span t-esc="line['name']" /></span>
													</t> -->
												</td>

												<td style="text-align:right !important;padding:20.0px">
													<span t-esc="line['debit']" t-options="{'widget': 'monetary', 'display_currency': line['currency_id']}" />
												</td>
												<td style="text-align:right !important;padding:20.0px">
													<span t-esc="line['credit']" t-options="{'widget': 'monetary', 'display_currency': line['currency_id']}" />
												</td>
												<td t-if="not data['form']['with_null_amount_residual']" style="text-align:right !important;padding:20.0px">
													<span t-esc="line['due']" t-options="{'widget': 'monetary', 'display_currency': line['currency_id']}"/>
												</td>
												<td t-if="data['form']['with_null_amount_residual']" style="text-align:right !important">
													<t t-set="bal"
														t-value="line['debit'] - line['credit'] +  bal" />
													<span t-esc="bal"
														t-options="{'widget': 'monetary', 'display_currency': line['currency_id']}" />
												</td>
												<t t-set="total"
													t-value="{'d':total['d']+line['debit'],'c':total['c']+line['credit'], 'r':total['r']+line['due']}" />
											</tr>


											<tr >
<!-- 												<td /> -->
												<td />
												<td>Total</td>
												<td style="text-align:right !important;">
													<strong t-esc="total['d']"
														t-options="{'widget': 'monetary', 'display_currency': cu['cu']}" />
												</td>
												<td style="text-align:right !important;">

													<strong t-esc="total['c']"
														t-options="{'widget': 'monetary', 'display_currency': cu['cu']}" />

												</td>
												<td  t-if="not data['form']['with_null_amount_residual']" style="text-align:right !important;">

													<strong t-esc="total['r']"
														t-options="{'widget': 'monetary', 'display_currency': cu['cu']}" />

												</td>
												<td t-if="data['form']['with_null_amount_residual']" style="text-align:right !important;">
													<strong t-esc="total['d'] - total['c']"
														t-options="{'widget': 'monetary', 'display_currency': cu['cu']}" />
												</td>
											</tr>
										</t>
									</tbody>
								</table>
							</t>
						</div>
					</t>
				</t>
			</t>
		</template>

<!--		<report id="action_report_partnerledger"-->
<!--			model="account.report.partner.ledger" string="Partner Ledger"-->
<!--			report_type="qweb-pdf" name="erpc_customer_statement_report.partnerledger"-->
<!--			file="erpc_customer_statement_report.partnerledger" />-->


		<record id="action_report_partnerledger" model="ir.actions.report">
            <field name="name">Partner Ledger</field>
            <field name="model">account.report.partner.ledger</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">erpc_customer_statement_report.partnerledger</field>
            <field name="report_file">erpc_customer_statement_report.partnerledger</field>
            <field name="binding_view_types">form</field>
        </record>

	</data>
</odoo>
