<odoo>
    <record id="stock_lot_view_form_inherit" model="ir.ui.view">
        <field name="name">stock.lot.form.inherit</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="active" invisible="1"/>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <div class="oe_button_box" name="button_box">
                    <button name="archive_lot" type="object" string="Archive" class="oe_stat_button" icon="fa-archive" invisible="active != True"/>
                    <button name="unarchive_lot" type="object" string="Unarchive" class="oe_stat_button" icon="fa-refresh" invisible="active == True"/>
                </div>
            </xpath>
        </field>
    </record>

    <record id="stock_lot_view_tree_inherit" model="ir.ui.view">
        <field name="name">stock.lot.tree.inherit</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.view_production_lot_tree"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="active" column_invisible="1"/>
            </field>
        </field>
    </record>

    <record id="stock_lot_view_search_inherit" model="ir.ui.view">
        <field name="name">stock.lot.search</field>
        <field name="model">stock.lot</field>
        <field name="inherit_id" ref="stock.search_product_lot_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='creation_date']" position="after">
                <filter string="Archived" name="inactive" domain="[('active','=',False)]"/>
            </xpath>
        </field>
    </record>
</odoo>