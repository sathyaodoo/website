<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_inherit_expected_arrival" model="ir.ui.view">
        <field name="name">account.move.expected.arrival</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='aml_tab']/field[@name='line_ids']/tree[1]/field[@name='analytic_distribution']" position="after">
                <field optional="show" name="expected_arrival_date"/>
            </xpath>
        </field>
    </record>
    <record id="view_move_inherit_expected_arrival_tree" model="ir.ui.view">
        <field name="name">account.move.expected.arrival.tree</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree[1]/field[@name='amount_currency']" position="after">
                <field optional="show" name="expected_arrival_date"/>
            </xpath>
        </field>
    </record>
</odoo>