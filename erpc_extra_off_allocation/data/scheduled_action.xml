<odoo>
    <record id="ir_cron_extra_sundays_base_on_daily_attendance" model="ir.cron">
        <field name="name">ERPC: Auto Allocate Sunday Leaves Based on Daily Attendance</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave_allocation"/>
        <field name="state">code</field>
        <field name="code">model.allocate_extra_off_hours()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="active" eval="False"/>
    </record>

    <record id="ir_cron_allocate_sunday_leave" model="ir.cron">
        <field name="name">ERPC: Allocate Sunday Leave for Syrian Employees</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave_allocation"/>
        <field name="state">code</field>
        <field name="code">model.allocate_sunday_leave()</field>
        <field name="interval_type">weeks</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
        <field name="active" eval="True"/>
        <field name="interval_number">1</field>
    </record>
</odoo>
