<odoo>
    <template id="erpc_inherit_main_pdf_export_main" inherit_id="account_reports.pdf_export_main">
        <xpath expr="//body/div/header" position="replace">
            <header>
                <div class="o_account_reports_header print_only">
                    <div class="row">
                        <div class="col-3 mb4">
                            <img t-if="env.company.logo" t-att-src="image_data_uri(env.company.logo)"
                                 style="max-height: 45px;" alt="Company Logo"/>
                        </div>
                    </div>
                    <br></br>
                    <div class="row zero_min_height">
                        <div class="col-12">
                            <div style="border-bottom: 1px solid black;"/>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-6" name="company_address">
                            <ul class="list-unstyled">
                                <li t-if="env.company.is_company_details_empty">
                                    <t t-esc="env.company.partner_id"
                                       t-options="{&quot;widget&quot;: &quot;contact&quot;, &quot;fields&quot;: [&quot;address&quot;, &quot;name&quot;], &quot;no_marker&quot;: true}"/>
                                </li>
                                <li t-else="">
                                    <t t-esc="env.company.company_details"/>
                                </li>
                                <li t-if="env.company.country_id.vat_label">
                                    <t t-esc="env.company.country_id.vat_label"/>:
                                    <span t-esc="env.company.vat"/>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </header>
        </xpath>
    </template>
</odoo>