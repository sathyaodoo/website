<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="hr_rule_bonus" model="hr.salary.rule">
            <field name="code">BON</field>
            <field name="name">Bonus</field>
            <field name="category_id" ref="hr_payroll.ALW"/>
            <field name="condition_select">python</field>
            <field name="condition_python">result = 'BON' in inputs</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">result = inputs['BON'] and + inputs['BON'].amount</field>
            <field name="appears_on_payslip" eval="True"/>
            <field name="sequence" eval="4"/>
            <field name="struct_id" ref="erpc_hr_payroll_extension.erpc_structure"/>
        </record>

        <record id="hr_rule_input_bonus" model="hr.payslip.input.type">
            <field name="code">BON</field>
            <field name="name">Bonus</field>
        </record>
    </data>
</odoo>
