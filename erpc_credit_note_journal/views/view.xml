<odoo>
    <record id="account.action_move_out_refund_type" model="ir.actions.act_window">
        <field name="domain">[('move_type', '=', 'out_refund')]</field>
        <field name="context">{'default_move_type': 'out_refund', 'default_journal_id': 41}</field>
    </record>

    <record id="yoko_customization.action_move_out_refund_invoice_return" model="ir.actions.act_window">
        <field name="domain">[('move_type', '=', 'out_refund')]</field>
        <field name="context">{'default_move_type': 'out_refund', 'default_journal_id': 42}</field>
    </record>

    <record id="account_move_view_form_inherit" model="ir.ui.view">
        <field name="name">account.move.view.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
<!--            <xpath expr="//field[@name='invoice_date']" position="after">-->
<!--                <field name="is_credit_note" widget="boolean_toggle"/>-->
<!--            </xpath>-->
            <xpath expr="//button[@name='action_reverse']" position="attributes">
                <attribute name="context">
                    {'default_journal_id': 41, 'credit_note': True}
                </attribute>
            </xpath>
<!--            <xpath expr="//button[@name='action_reverse_new']" position="attributes">-->
<!--                <attribute name="context">-->
<!--                    {'default_journal_id': 42, 'credit_note': False}-->
<!--                </attribute>-->
<!--            </xpath>-->
        </field>
    </record>
</odoo>
