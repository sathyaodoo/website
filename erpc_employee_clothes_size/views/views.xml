<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="erpc_res_config_settings_view_form_inherit_hr_monthly_hours" model="ir.ui.view">
        <field name="name">res.config.settings.hr.monthly.hours</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='employees_setting_container']" position="inside">
                <setting string="Monthly Working Hours for Hourly Cost" id="monthly_hours_setting">
                    <div class="content-group">
                        <div class="row mt8">
                            <label for="monthly_hours" class="col-lg-4 o_light_label"/>
                            <field name="monthly_hours" class="col-lg-8"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>


    <record id="view_employee_form_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.clothes.size</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="after">
                <field name="clothes_size" string="Clothes Size"/>
            </xpath>
<!--            <xpath expr="//field[@name='parent_id']" position="after">-->
<!--                <field name="home_allowance" groups="hr.group_hr_user" invisible="country_id == 126"/>-->
<!--            </xpath>-->

        </field>
    </record>
</odoo>