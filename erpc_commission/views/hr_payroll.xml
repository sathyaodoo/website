<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_payslip_form_inherit_view_commission" model="ir.ui.view">
        <field name="name">hr.payslip.inherit.form1.commission</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='input_line_ids']//list//field[@name='sequence']" position="after">
                <field name="commission_line_id" column_invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>