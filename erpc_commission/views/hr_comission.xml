<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--Commission Tree view-->
    <record id="hr_commission_tree_view" model="ir.ui.view">
        <field name="name">hr.commission.tree</field>
        <field name="model">hr.commission</field>
        <field name="arch" type="xml">
            <list string="Sales Incentives">
                <field name="name"/>
                <field name="employee_id"  readonly="paid == True"/>
                <field name="commission_amount"  readonly="paid == True"/>
                <field name="batch_id"/>
                <field name="paid" readonly="1"/>
                <field name="tires_qty" optional="show"/>
                <field name="tires_values" optional="show"/>
                <field name="batteries_qty" optional="show"/>
                <field name="batteries_values" optional="show"/>
                <field name="oil_qty" optional="show"/>
                <field name="oil_values" optional="show"/>
                <field name="note" optional="show"/>
                <field name="currency_id" optional="show"/>
            </list>
        </field>
    </record>

    <!--Commission Form view-->
    <record id="hr_commission_form_view" model="ir.ui.view">
        <field name="name">hr.commission.form</field>
        <field name="model">hr.commission</field>
        <field name="arch" type="xml">
            <form string="Sales Incentives">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group col="4">
                        <field name="employee_id" readonly="paid == True"/>
                        <field name="date" readonly="paid == True"/>
                        <field name="department_id"/>
                        <field name="job_position"/>
                        <field name="commission_amount" readonly="paid == True"/>
                        <field name="payslip_id" invisible="1"/>
                        <field name="batch_id"/>
                        <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                        <field name="currency_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                        <field name="paid" readonly="1" invisible="1"/>
                        <field name="tires_qty"/>
                        <label for="tires_values"/>
                        <div name="tires_values" class="o_row">
                            <span style="width:5px;">
                                <field name="tires_values"/>
                            </span>
                            <field name="currency_id" options="{'no_create': True, 'no_open': True}" groups="base.group_multi_currency" readonly="1" style="margin-right: 20px;"/>
                        </div>
                        <field name="batteries_qty"/>
                        <label for="batteries_values"/>
                        <div name="batteries_values" class="o_row">
                            <span style="width:5px;">
                                <field name="batteries_values"/>
                            </span>
                            <field name="currency_id" options="{'no_create': True, 'no_open': True}" groups="base.group_multi_currency" readonly="1" style="margin-right: 20px;"/>
                        </div>
                        <field name="oil_qty"/>
                        <label for="oil_values"/>
                        <div name="oil_values" class="o_row">
                            <span style="width:5px;">
                                <field name="oil_values"/>
                            </span>
                            <field name="currency_id" options="{'no_create': True, 'no_open': True}" groups="base.group_multi_currency" readonly="1" />
                        </div>
                        <field name="note"/>
                    </group>
                </sheet>
                <chatter>
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="message_ids" widget="mail_thread"/>
                </chatter>
            </form>
        </field>
    </record>

    <!--commission  search view-->
    <record id="view_commission_request_search_form" model="ir.ui.view">
        <field name="name">hr.commission.search.form</field>
        <field name="model">hr.commission</field>
        <field name="arch" type="xml">
            <search string="Sales Incentives">
                <field name="employee_id" string="Employee"/>
                <field name="department_id" string="Department"/>
                <field name="batch_id" string="Payslip Batch"/>
                <filter string="Payslip Batch" name="batch_id" context="{'group_by':'batch_id'}"/>
                <filter string="Employee" name="employee_id" context="{'group_by':'employee_id'}"/>
                <filter string="Department" name="department_id" context="{'group_by':'department_id'}"/>
                <filter string="Description" name="note" context="{'group_by':'note'}"/>
                <filter string="Date" name="date" context="{'group_by':'date:month'}"/>
            </search>
        </field>
    </record>


    <!--commission  menu-->
    <record id="action_hr_commission_request" model="ir.actions.act_window">
        <field name="name">Sales Incentives</field>
        <field name="res_model">hr.commission</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_myrequest': 1}</field>
        <field name="search_view_id" ref="view_commission_request_search_form"/>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new Sales Incentives.
            </p>
            <p>
                Use this menu to create Sales Incentives.
            </p>
        </field>
    </record>

    <menuitem name="Sales Incentives" parent="erpc_hr_payroll_extension.menu_hr_allowances" id="menu_hr_commission" action="action_hr_commission_request"/>

    <!-- Shortcuts -->
    <record id="act_hr_employee_commission_request" model="ir.actions.act_window">
        <field name="name">Sales Incentives</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">hr.commission</field>
        <field name="binding_model_id" ref="hr.model_hr_employee"/>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="hr_commission_tree_view"/>
    </record>


    <!-- HR employee inherit commission -->
    <record id="view_employee_form_insurance_inherit" model="ir.ui.view">
        <field name="name">hr.employee.company.commission.form.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="priority" eval="10000"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="%(act_hr_employee_commission_request)d" type="action" class="oe_stat_button" icon="fa-percent" groups="hr.group_hr_manager,hr.group_hr_user">
                    <field name="commission_count" widget="statinfo" string="Sales Incentives"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
