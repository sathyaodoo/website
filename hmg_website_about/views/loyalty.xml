<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="loyalty_page" name="Loyalty Page">
        <t t-call="website.layout">
            <div class="container" style="padding:60px 0;">
                
                <!-- Page Header -->
                <h4 style="font-weight:700; text-align:center;">
                    Loyalty
                </h4>


                <!-- Grey Line -->
                <div style="width:100%; height:1px; background:#d3d3d3; margin:20px 0;"></div>
                <!-- Gap -->
                <div style="margin-top:40px;"></div>
    
                <!-- Points -->
                <h4 style="color:red; font-weight:700; text-align:center; ">
                    You Have 100 Points
                </h4>
    
                <!-- Description -->
                <h6 style="margin-top:10px; text-align:center;">
                    Each point is equivalent to 1 tire
                </h6> 
                
                <!-- Gap -->
                <div style="margin-top:40px;"></div>
                
                <!-- Loyalty Table -->
                <table style="width:100%; border-collapse:collapse; text-align:left;">
                
                    <!-- Table Header -->
                    <thead>
                        <tr style="background:#d40000; color:white;">
                            <th style="padding:12px;">Amount</th>
                            <th style="padding:12px;">Reason</th>
                            <th style="padding:12px;">Date</th>
                            <th style="padding:12px;">Receipt</th>
                        </tr>
                    </thead>
                
                    <!-- Table Body -->
                    <tbody>
                        <tr style="border-bottom:1px solid #ddd;">
                            <td style="padding:12px;">+10</td>
                            <td style="padding:12px;">Purchase</td>
                            <td style="padding:12px;">01 Mar 2026</td>
                            <td style="padding:12px;">
                                <a href="#" style="color:#d40000; font-size:18px; text-decoration:none;">
                                    <i class="fa fa-file"></i>
                                </a>
                            </td>
                        </tr>
                
                        <tr style="border-bottom:1px solid #ddd;">
                            <td style="padding:12px;">+5</td>
                            <td style="padding:12px;">Promotion</td>
                            <td style="padding:12px;">25 Feb 2026</td>
                            <td style="padding:12px;">
                                <a href="#" style="color:#d40000; font-size:18px; text-decoration:none;">
                                    <i class="fa fa-file"></i>
                                </a>
                            </td>
                        </tr>
                
                        <tr style="border-bottom:1px solid #ddd;">
                            <td style="padding:12px;">-2</td>
                            <td style="padding:12px;">Redeemed</td>
                            <td style="padding:12px;">20 Feb 2026</td>
                            <td style="padding:12px;">
                                <a href="#" style="color:#d40000; font-size:18px; text-decoration:none;">
                                    <i class="fa fa-file"></i>
                                </a>
                            </td>
                        </tr>
                    </tbody>
                
                </table>


            </div>
        </t>
    </template>

</odoo>