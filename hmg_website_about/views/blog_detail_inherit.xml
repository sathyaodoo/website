<odoo>

    <template id="custom_blog_detail"
              inherit_id="website_blog.blog_post_complete"
              name="Custom Blog Detail Layout">

        <!-- Remove Cover Section -->
        <xpath expr="//section[@id='o_wblog_post_top']" position="replace"/>

        <!-- Replace Main Blog Content Section -->
        <xpath expr="//section[@id='o_wblog_post_main']" position="replace">

            <section id="o_wblog_post_main" class="container py-5">

                <div class="row align-items-start">

                    <!-- LEFT IMAGE -->
                    <div class="col-lg-6 mb-4">
                        <img t-if="blog_post.news_image"
                             t-att-src="'/web/image/blog.post/%s/news_image' % blog_post.id"
                             class="img-fluid rounded shadow"/>
                    </div>

                    <!-- RIGHT CONTENT -->
                    <div class="col-lg-6 position-relative"
                        t-attf-style="background-image: url('/hmg_website_about/static/src/img/news/news.png');
                                    background-repeat: no-repeat;
                                    background-position: top right;
                                    background-size: 435px;">

                        <!-- Top Bar -->
                        <div class="d-flex justify-content-between align-items-center mb-3">

                            <!-- Social Icons -->
                            <div class="d-flex gap-3">

                                <!-- WhatsApp -->
                                <a t-att-href="'https://wa.me/?text=' + request.httprequest.url"
                                target="_blank"
                                class="text-success fs-5">
                                    <i class="fa fa-whatsapp"/>
                                </a>

                                <!-- Twitter -->
                                <a t-att-href="'https://twitter.com/intent/tweet?url=' + request.httprequest.url"
                                target="_blank"
                                class="text-dark fs-5">
                                    <i class="fa fa-twitter"/>
                                </a>

                                <!-- Facebook -->
                                <a t-att-href="'https://www.facebook.com/sharer/sharer.php?u=' + request.httprequest.url"
                                target="_blank"
                                class="text-primary fs-5">
                                    <i class="fa fa-facebook"/>
                                </a>

                            </div>


                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="d-flex gap-3" style="margin-top: 120px;">
                                 <!-- Close Button -->
                                <a href="/news"  class="text-dark fs-5 text-decoration-none">
                                <i class="fa fa-times"/>
                                </a>
                                
                                </div>
                            
                        </div>

                        <!-- Date -->
                        <p class="text-muted mb-2"
                        style="font-size:14px; letter-spacing:1px; margin-left: 0px; margin-top: -5px;">
                            <t t-esc="blog_post.post_date.strftime('%d %b %Y') if blog_post.post_date else ''"/>
                        </p>

                        <!-- Title -->
                        <h2 class="fw-bold mb-4" style="margin-top:50px;">
                            <t t-esc="blog_post.name"/>
                        </h2>

                        <!-- Content -->
                        <div class="text-muted"
                            style="line-height:1.8; font-size:15px; margin-top:-14px;">
                            <t t-raw="blog_post.subtitle"/>
                        </div>

                    </div> 

                </div>

            </section>

        </xpath>

    </template>

</odoo>