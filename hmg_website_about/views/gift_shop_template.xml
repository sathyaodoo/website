<odoo>

    <template id="gift_shop_page" name="Gift Shop">

        <t t-call="website.layout">

            <div class="container py-5">

            <!-- HEADER -->

            <div class="gift-header d-flex align-items-center justify-content-center">
                <h3 class="gift-title">
                    YOU HAVE 100 POINTS TO REDEEM
                </h3>
            </div>

            <!-- PRODUCTS -->

            <div class="row g-4">

            <t t-foreach="gifts" t-as="gift">

            <div class="col-lg-3 col-md-4 col-sm-6">

            <div class="gift-card text-center">

            <img t-att-src="'/web/image/product.template/%s/image_1920' % gift['id']"
                class="gift-image"/>

            <div class="gift-body">

            <h6 class="gift-name">
            <t t-esc="gift['name']"/>
            </h6>

            <div class="gift-points">
            <t t-esc="gift['points']"/> POINTS
            </div>

            <button class="btn btn-danger request-btn"
                    data-bs-toggle="modal"
                    data-bs-target="#giftModal"
                    t-att-data-name="gift['name']"
                    t-att-data-image="'/web/image/product.template/%s/image_1920' % gift['id']"
                    t-att-data-points="gift['points']">

            REQUEST

            </button>

            </div>

            </div>

            </div>

            </t>

            </div>

            </div>


<!-- POPUP -->
            <div class="modal fade" id="giftModal" tabindex="-1">

                <div class="modal-dialog modal-dialog-centered gift-modal-dialog">

                <div class="modal-content gift-modal-content">

                <div class="modal-header gift-modal-header">

                <h5 class="modal-title gift-modal-title">
                Are you sure you want to request this gift?
                </h5>

                <button type="button" class="btn-close"
                data-bs-dismiss="modal"></button>

                </div>

                <div class="modal-body gift-modal-body">

                <div class="row align-items-center">

                <div class="col-md-6">

                <img id="modal_image" class="gift-modal-image"/>

                </div>

                <div class="col-md-6 gift-details">

                <h5 id="modal_name" class="gift-product-title"></h5>

                <div class="gift-product-points">
                <span id="modal_points"></span> POINTS
                </div>

                <button class="btn gift-request-btn-popup">
                REQUEST
                </button>

                </div>

                </div>

                </div>

                </div>

                </div>

                </div>


            <!-- style -->

            <style>

            /* HEADER */

            .gift-header{
            background-image:url('/hmg_website_about/static/src/img/videos/video.jpg');
            background-size:cover;
            background-position:center;
            height:300px;
            position:relative;
            margin-bottom:60px;
            }

            .gift-header::before{
            content:'';
            position:absolute;
            top:0;
            left:0;
            width:100%;
            height:100%;
            background:rgba(0,0,0,0.45);
            }

            .gift-title{
            position:relative;
            color:white;
            font-size:42px;
            font-weight:700;
            letter-spacing:1px;
            }


            /* PRODUCT CARD */

            .gift-card{
            border:none;
            background:none;
            }

            /* PRODUCT IMAGE */

            .gift-image{
            width:100%;
            height:220px;
            object-fit:cover;
            display:block;
            }

            /* PRODUCT NAME */

            .gift-name{
            font-weight:600;
            margin-top:12px;
            }

            /* POINTS */

            .gift-points{
            color:#e30000;
            font-weight:700;
            margin-bottom:10px;
            }

            /* REQUEST BUTTON */

            .request-btn{
            border-radius:0 !important;
            padding:8px 28px;
            font-weight:600;
            }


            /* MODAL */

            .gift-modal-dialog{
            max-width:60%;
            }

            .gift-modal-content{
            border-radius:0;
            background:#f5f5f5;
            }

            /* MODAL HEADER */

            .gift-modal-header{
            padding:18px 25px;
            border-bottom:1px solid #e2e2e2;
            }

            .gift-modal-title{
            font-size:20px;
            font-weight:600;
            color:#333;
            }

            /* MODAL BODY */

            .gift-modal-body{
            padding:40px 45px;
            }

            /* MODAL IMAGE */

            .gift-modal-image{
            width:100%;
            height:240px;
            object-fit:cover;
            }

            /* MODAL RIGHT SIDE */

            .gift-details{
            padding-left:30px;
            }

            /* MODAL PRODUCT NAME */

            .gift-product-title{
            font-size:18px;
            font-weight:600;
            margin-bottom:8px;
            }

            /* MODAL POINTS */

            .gift-product-points{
            font-size:15px;
            font-weight:700;
            color:#e30000;
            margin-bottom:25px;
            }

            /* MODAL REQUEST BUTTON */

            .gift-request-btn-popup{
            background:#e30000;
            color:#fff;
            border:none;
            border-radius:0;
            padding:12px 55px;
            font-size:14px;
            font-weight:600;
            }

            .gift-request-btn-popup:hover{
            background:#c70000;
            }
             
            /* MOBILE VIEW — KEEP SAME AS DESKTOP */

@media (max-width:768px){

/* HEADER */

        .gift-header{
        background-image:url('/hmg_website_about/static/src/img/videos/video.jpg');
        background-size:cover;
        background-position:center;
        height:120px;
        display:flex;
        align-items:center;
        justify-content:center;
        }

.gift-title{
font-size:14px;
text-align:center;
padding:0 10px;
}


/* FORCE 4 CARDS IN ONE ROW */

.row.g-4{
display:flex;
flex-wrap:wrap;
}

.row.g-4 &gt; div{
width:25% !important;
max-width:25% !important;
flex:0 0 25% !important;
padding:8px;
}


/* PRODUCT IMAGE */

.gift-image{
width:90%;
height:80;
object-fit:cover;
}


/* PRODUCT TEXT */

.gift-name{
font-size:12px;
}

.gift-points{
font-size:12px;
}


/* REQUEST BUTTON */

.request-btn{
font-size:11px;
padding:6px 10px;
}


/* POPUP */

/* POPUP */

.gift-modal-dialog{
max-width:92%;
margin:auto;
}

.gift-modal-body{
padding:20px;
text-align:center;
}

.gift-modal-image{
height:170px;
width:150px;
display:block;
margin:0 auto 15px auto;
}

.gift-details{
text-align:center;
padding-left:0;
}

.gift-product-title{
font-size:16px;
text-align:center;
}

.gift-product-points{
font-size:14px;
text-align:center;
}

.gift-request-btn-popup{
padding:10px 30px;
font-size:13px;
display:block;
margin:10px auto 0 auto;
}

}

            </style>



            <!-- JAVASCRIPT -->

            <script>

            document.addEventListener("DOMContentLoaded", function () {

            document.querySelectorAll(".request-btn").forEach(function(btn){

            btn.addEventListener("click", function(){

            document.getElementById("modal_name").innerText =
            this.dataset.name;

            document.getElementById("modal_points").innerText =
            this.dataset.points;

            document.getElementById("modal_image").src =
            this.dataset.image;

            });

            });

            });

            </script>

        </t>

    </template>

</odoo>