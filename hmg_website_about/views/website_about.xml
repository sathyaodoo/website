    <script>
     function changeYear(year, element){
        const data = {
            "1995":{ title:"1995", subtitle:"A Legacy Begins", desc:"Hanna Howayek opens Lebanon’s first automotive import venture, laying the foundation for decades of innovation and trust." },
            "2005":{ title:"2005", subtitle:"HMG Holding is Born", desc:"Under Marwan Howayek, HMG Holding is established, securing exclusive Yokohama distribution rights and transforming a family legacy into a national force for mobility." },
            "2010":{ title:"2010", subtitle:"Expanding Expertise",desc:"HMG diversifies into ENI lubricants and Delkor batteries, bringing world-class performance and reliability to Lebanon’s roads.." },
            "2015":{ title:"2015", subtitle:"Nationwide Reach", desc:"Launch of a comprehensive logistics network, ensuring seamless distribution across all Lebanese territories." },
            "2020":{ title:"2020", subtitle:"Trusted by Thousands", desc:"Partnering with over 400 dealers and 100 fleet companies, HMG strengthens its role as Lebanon’s go-to mobility solutions provider." },
            "2025":{ title:"2025", subtitle:"Innovating for the Future", desc:"Introducing retail, e-commerce, and sustainability initiatives, continuing our mission to move Lebanon safely and efficiently into the next decade." }
        };
    
        
        document.getElementById("yearTitle").innerText = data[year].title;
        document.getElementById("yearSubtitle").innerText = data[year].subtitle;
        document.getElementById("yearDesc").innerText = data[year].desc;
    
        
        document.querySelectorAll('.timeline-item').forEach(el =&gt; {
            el.classList.remove('active');
        });
        element.classList.add('active');
    }
    
    function toggleWhy(element) {
        const parent = element.parentElement;
        const icon = element.querySelector(".why-icon");
    
        parent.classList.toggle("active");
    
        if (parent.classList.contains("active")) {
            icon.innerText = "-";
        } else {
            icon.innerText = "+";
        }
    }
    </script>
