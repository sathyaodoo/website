<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="hr_payslip_inherit" model="ir.ui.view">
        <field name="name">hr.payslip.inherit</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="statusbar_visible">
                    draft,done,paid
                </attribute>
            </xpath>

        </field>
    </record>

    <record id="hr_payslip_run_inherit" model="ir.ui.view">
        <field name="name">hr.payslip.run.inherit</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="statusbar_visible">
                    draft,done,paid
                </attribute>
            </xpath>
        </field>
    </record>
</odoo>
