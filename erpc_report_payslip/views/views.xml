<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="erpc_paperformat_payslip_report" model="report.paperformat">
        <field name="name">Payslip Reports A4</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="page_height">0</field>
        <field name="page_width">0</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">30</field>
        <field name="margin_bottom">20</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">30</field>
        <field name="dpi">90</field>
    </record>

    <record id="hr_payroll.action_report_payslip" model="ir.actions.report">
        <field name="paperformat_id" ref="erpc_paperformat_payslip_report"/>
    </record>

    <template id="external_id_inheritLM" inherit_id="web.external_layout_standard">
        <xpath expr="//div[@class='col-3 mb4']" position="replace">
            <img t-att-src="'/web/image/res.company/1/logo'"
                 style="max-height: 100px; max-width: 60%; padding-top: 10px"/></xpath>
    </template>
    <template id="erpc_report_payslip_inherit" inherit_id="hr_payroll.report_payslip">

        <xpath expr="//table[@name='employee-infos']" position="replace">
            <style>
                .page {
                margin-top: 10px;
                }

                .master_lines {
                border-bottom-width: 1px;
                border-bottom-style: solid;
                font-size: 20px;
                min-height: 30px;
                display: flex;
                align-items: center;
                }

                .box-inv2 {
                white-space: nowrap;
                display: -webkit-box; /* wkhtmltopdf uses this one */
                display: flex;
                -webkit-box-pack: justify; /* wkhtmltopdf uses this one */
                justify-content: space-evenly;
                margin: 0 auto;
                }

                .header-text {
                font-size: 25pt; /* Use for section headers like 'INVOICE' */
                }

                .row {
                display: flex;
                justify-content: space-between;
                align-items: flex-start;
                }

                .col-5 {
                width: 45%;
                }

                .text-left {
                text-align: left;
                }

                .left-col, .right-col {
                display: flex;
                flex-direction: column;
                min-height: 200px; /* Ensure equal height even if there's less content */
                }

                .left-col .master_lines, .right-col .master_lines {
                margin-bottom: 10px; /* Ensures space between rows */
                }

                .left-col .master_lines:last-child, .right-col .master_lines:last-child {
                margin-bottom: 0; /* Remove bottom margin for the last row */
                }

                .row > .col-2 {
                width: 10%; /* This keeps the empty middle column for alignment */
                }

                .one-line-address {
                white-space: nowrap;
                font-size: 14px;
                }

                .address-line {
                flex: 1; /* Allow address lines to wrap */
                }
            </style>

            <div class="row">
                <div class="col-5 text-left left-col">
                    <table class="table-borderless">
                        <tr>
                            <td><strong>Employee:</strong></td>
                            <td><span t-field="o.employee_id">John Smith</span></td>
                        </tr>
                        <tr>
                            <td><strong>Marital Status:</strong></td>
                            <td><span t-field="o.employee_id.marital">Married</span></td>
                        </tr>
                        <tr>
                            <td><strong>Job Position:</strong></td>
                            <td><span t-field="o.employee_id.job_title">Software Engineer</span></td>
                        </tr>
                        <tr>
                            <td><strong>Pay Period:</strong></td>
                            <td>
                                <span t-if="o.date_from &lt; o.contract_id.date_start"
                                      t-field="o.contract_id.date_start">Start Date</span>
                                <span t-else="" t-field="o.date_from">From</span>
                                <span t-if="o.contract_id.date_end and o.date_to &gt; o.contract_id.date_end"
                                      t-field="o.contract_id.date_end">End Date</span>
                                <span t-else="" t-field="o.date_to">To</span>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Address:</strong></td>
                            <td>
                                <t t-if="o.employee_id.private_street">
                                    <span t-esc="o.employee_id.private_street"/>
                                </t>
                                <t t-if="o.employee_id.private_city">
                                    <t t-if="o.employee_id.private_street">, </t>
                                    <span t-esc="o.employee_id.private_city"/>
                                </t>
                                <t t-if="o.employee_id.private_zip">
                                    <t t-if="o.employee_id.private_street or o.employee_id.private_city">, </t>
                                    <span t-esc="o.employee_id.private_zip"/>
                                </t>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <strong>Working Spouse: </strong></td>
                            <td>
                                <span>
                                    <t t-if="o.employee_id.x_studio_working_spouse">Yes</t>
                                    <t t-else="">No</t>
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>SSN No:</strong></td>
                            <td>
                                <span>
                                    <t t-if="o.employee_id.ssnid"><span t-esc="o.employee_id.ssnid"/></t>
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <strong>Working Schedule:</strong>
                            </td>
                            <td><span t-field="o.employee_id.contract_id.resource_calendar_id">40</span></td>
                        </tr>

                    </table>
                </div>

                <div class="col-2 text-left"/>
                <div class="col-5 text-left right-col">
                    <table class="table-borderless">
                        <tr>
                            <td>
                                <strong>Birthday:</strong>
                            </td>
                            <td><t t-if="o.employee_id.birthday">
                                <span t-out="o.employee_id.birthday"></span>
                            </t>

                            </td>
                        </tr>
                        <tr>
                            <td>
                                <strong>Nationality:</strong>
                            </td>
                            <td><t t-if="o.employee_id.country_id.name">
                                <span t-out="o.employee_id.country_id.name"></span>
                            </t>

                            </td>
                        </tr>

                        <tr>
                            <td>
                                <strong>Number Dependent Kids:</strong>
                            </td>
                            <td><t t-if="o.employee_id.children">
                                <span t-out="o.employee_id.children"></span>
                            </t>

                            </td>
                        </tr>
                        <tr>
                            <td>
                                <strong>Identification:</strong>
                            </td>
                            <td>
                                <t t-if="o.employee_id.identification_id">
                                    <span t-field="o.employee_id.identification_id"></span>
                                </t>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <strong>Computed on:</strong>
                            </td>
                            <td>
                                <t t-if="o.compute_date">
                                    <span t-field="o.compute_date"></span>
                                </t>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <strong>Contract Start Date:</strong>
                            </td>
                            <td><span t-field="o.employee_id.first_contract_date">2023-09-10</span></td>
                        </tr>
                        <tr>
                            <td>
                                <strong>Contract Type:</strong>
                            </td>
                            <td><span t-field="o.employee_id.contract_id.contract_type_id">Full Time</span></td>
                        </tr>

                    </table>


                </div>
            </div>

        </xpath>
        <xpath expr="//table[@class='table table-sm']" position="replace"/>
        <xpath expr="//div[@id='total']/table" position="replace">
            <table class="table table-sm">
                <thead class="o_black_border">
                    <tr>
                        <th id="line_header_name">Name</th>
                        <th id="line_header_hours">Number of Hours</th>
                        <th id="line_header_days">Number of Days</th>
                        <th id="line_header_amount" class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    <t id="worked_days_lines">
                        <span t-foreach="o.worked_days_line_ids.filtered(lambda worked_days: worked_days.code == 'WORK_HOURS')"
                              t-as="worked_days">
                            <tr style="color:none">
                                <td id="worked_days_name">
                                    <span t-field="worked_days.name">Regular Hours</span>
                                </td>
                                <td id="worked_days_hours"><span t-field="worked_days.number_of_hours">8</span></td>
                                <td id="worked_days_days"><span t-field="worked_days.number_of_days">5</span></td>
                            </tr>
                        </span>
                    </t>
                    <t id="payslip_lines">
                        <span t-foreach="o.line_ids.filtered(lambda line: line.appears_on_payslip)" t-as="line">
                            <t t-set="line_styling" t-value="line.get_payslip_styling_dict()"/>
                            <t t-set="line_style"/>
                            <t t-set="line_class"/>
                            <t t-if="line.code in line_styling">
                                <t t-set="line_style" t-value="line_styling[line.code]['line_style']"/>
                                <t t-set="line_class" t-value="line_styling[line.code]['line_class']"/>
                            </t>
                            <tr t-att-class="line_class" t-att-style="line_style" id="line_display">
                                <td id="payslip_line_name"><span t-field="line.name"/></td>
                                <td id="payslip_line_rate"></td>
                                <td id="payslip_line_quantity"><span t-if="line.quantity > 1"
                                                                     t-esc="line.quantity"/></td>
                                <td id="payslip_line_total" class="text-end"><span t-esc="line.total"
                                                                                   t-options='{"widget": "monetary", "display_currency": o.company_id.currency_id}'
                                                                                   t-att-style="'color:#875A7B;' if line.total &lt; 0 else ''"/></td>
                            </tr>
                        </span>
                    </t>
                </tbody>
            </table>

        </xpath>
        <xpath expr="//div[@id='to_pay']" position="replace">
            <div>
                <p>I declare that I have received from Marwan Howayek SARL all amounts and compensation due to me to date,
                    and thus I have received all my rights in the company of any kind whatsoever, whether in terms of
                    warning, previous salaries, annual leave, overtime or any other rights of any kind or entity prior to
                    its date and related to my work in the said company.
                    I discharge the company and all its directors from liability for a final and complete general discharge,
                    stating that I no longer have any account or demand whatsoever of any kind or entity, and for the
                    validity of my declaration, my termination of my rights and the company's clearance,
                    I sign with my consent and without reservation.</p>
                <div class="row">
                    <div class="col-5 text-left left-col">
                        <span>Signature:</span>
                        <t t-if="o.signature">
                            <img t-if="o.signature" t-att-src="'data:image/png;base64,' + o.signature.decode('utf-8')"
                                 style="width: 200px; height: 80px;"/>
                        </t>
                    </div>
                    <div class="col-5 text-left right-col" style="margin-top: 28px;">
                        <span>Date:</span>
                    </div>
                </div>
            </div>
        </xpath>


