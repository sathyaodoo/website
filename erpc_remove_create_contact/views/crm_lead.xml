<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="erpc_crm_lead_form_inherit" model="ir.ui.view">
        <field name="name">erpc.crm.lead.form.inherit</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form[1]/sheet[1]/group[1]/group[@name='lead_partner']/field[@name='partner_id']" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
            <xpath expr="//form[1]/sheet[1]/group[1]/group[@name='opportunity_partner']/field[@name='partner_id']" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
        </field>
    </record>
    <record id="erpc_website_crm_lead_form_inherit" model="ir.ui.view">
        <field name="name">erpc.website.crm.lead.form.inherit</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="website_crm_partner_assign.view_crm_lead_opportunity_geo_assign_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_assigned_id']" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
        </field>
    </record>

    <record id="erpc_crm_lead_quick_create_inherit" model="ir.ui.view">
        <field name="name">erpc.crm.lead.quick.inherit</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.quick_create_opportunity_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="options">{'no_create': True}</attribute>
            </xpath>
        </field>
    </record>
</odoo>