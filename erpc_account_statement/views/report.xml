<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_account_move_line" model="ir.actions.report">
        <field name="name">currency_soa</field>
        <field name="model">account.debit.credit.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">erpc_account_statement.report_account_move_line_foreign</field>
        <field name="report_file">erpc_account_statement.report_account_move_line_foreign</field>
        <field name="binding_model_id" ref="model_account_debit_credit_wizard"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_account_move_line_foreign">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    Date from :
                    <span t-esc="wizard['from_date']"/>
                    <br></br>
                    Date to :
                    <span t-esc="wizard['to_date']"/>
                    <br></br>
                    Account :
                    <span t-esc="wizard['account_id'][1]"/>
                    <br></br>

                    <t t-if="wizard['partner_id']">
                        Partner :
                        <span t-esc="wizard['partner_id']"/>
                        <br></br>
                    </t>
                    <t t-foreach="currency_groups" t-as="currency_group">
                        <table class="table table-condensed">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Account</th>
                                    <th>Label</th>
                                    <th>Amount in Currency</th>
                                    <th>Debit</th>
                                    <th>Credit</th>
                                    <th>Balance</th>
                                    <th>Cumulative</th>
                                    <th t-esc="currency_group['currency_code']"/>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="cumulative" t-value="0"/>
                                <t t-foreach="currency_group['lines']" t-as="line">
                                    <tr>
                                        <td style="white-space:nowrap">
                                            <span t-if="line['date']" t-esc="line['date']"/>
                                        </td>
                                        <td>
                                            <span t-if="line['account_id']" t-esc="line['account_id'][1]"/>
                                        </td>
                                        <td>
                                            <span t-if="line['name']" t-esc="line['name']"/>
                                        </td>

                                        <td>
                                            <span t-if="line['amount_currency']" t-esc="line['amount_currency']"
                                                  t-options="{'widget': 'float', 'precision': 2}"/>
                                        </td>
                                       <td>
                                            <span t-if="line['debit']" t-esc="line['debit']"
                                                  t-options="{'widget': 'float', 'precision': 2}"/>
                                        </td>
                                        <td>
                                            <span t-if="line['credit']" t-esc="line['credit']"
                                                  t-options="{'widget': 'float', 'precision': 2}"/>
                                        </td>
                                        <td>
                                            <span t-if="line['balance']" t-esc="line['balance']"
                                                  t-options="{'widget': 'float', 'precision': 2}"/>
                                        </td>

                                        <td>
                                            <t t-set="cumulative"
                                               t-value="cumulative + line['debit'] - line['credit']"/>
                                            <span t-esc="cumulative"
                                                  t-options="{'widget': 'float', 'precision': 2}"/>
                                        </td>
                                    </tr>
                                </t>
                                <tr>
                                    <td colspan="4">
                                        <strong>Total</strong>
                                    </td>
                                    <td>
                                        <span t-esc="currency_group['total_debit']"
                                              t-options="{'widget': 'float', 'precision': 2}"/>
                                    </td>
                                    <td>
                                        <span t-esc="currency_group['total_credit']"
                                              t-options="{'widget': 'float', 'precision': 2}"/>
                                    </td>
                                    <td>
                                        <span t-esc="currency_group['total_balance']"
                                              t-options="{'widget': 'float', 'precision': 2}"/>
                                    </td>
                                    <td>
                                        <span t-esc="cumulative"
                                              t-options="{'widget': 'float', 'precision': 2}"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </t>
                </div>
            </t>
        </t>
    </template>
</odoo>