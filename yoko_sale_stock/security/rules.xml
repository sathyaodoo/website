<odoo>
    <record model="ir.rule" id="rule_sale_order_promo">
        <field name="name">Promotional Sale Orders Team</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="domain_force">[('is_promo','=',True)]</field>
        <field name="groups" eval="[(4, ref('yoko_security_custom.advertising_department'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <record model="ir.rule" id="rule_sale_order_line_promo">
        <field name="name">Promotional Sale Order Lines Team</field>
        <field name="model_id" ref="sale.model_sale_order_line"/>
        <field name="domain_force">[('order_id.is_promo','=',True)]</field>
        <field name="groups" eval="[(4, ref('yoko_security_custom.advertising_department'))]"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>
</odoo>