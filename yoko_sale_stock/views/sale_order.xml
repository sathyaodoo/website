<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_form_sale_order_promotional" model="ir.ui.view">
            <field name="name">view.form.sale.order.promotional</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <field name="partner_id" position="before">
                    <field name="is_promo" invisible="1"/>
                </field>
                <xpath expr="/form/sheet/notebook/page[@name='order_lines']/field[@name='order_line']/list//field[@name='product_id']" position="attributes">

                    <attribute name="domain">
                        [('advertising', '=', parent.is_promo), ('sale_ok', '=', True), '|', ('company_id', '=', False),
                         ('company_id', '=', parent.company_id)]
                    </attribute>
                </xpath>
                <!-- <xpath expr="//field[@name='order_line']//form//field[@name='product_id']" position="attributes"> 
                    <attribute name="domain">
                        [('advertising', '=', parent.is_promo), ('sale_ok', '=', True), '|', ('company_id', '=', False),
                         ('company_id', '=', parent.company_id)]
                    </attribute>
                </xpath> -->
                <xpath expr="/form/sheet/notebook/page[@name='order_lines']/field[@name='order_line']/list//field[@name='product_template_id']" position="attributes">
                    <attribute name="domain">
                        [('advertising', '=', parent.is_promo), ('sale_ok', '=', True), '|', ('company_id', '=', False),
                         ('company_id', '=', parent.company_id)]
                    </attribute>
                </xpath>

                <xpath expr="/form/sheet/notebook/page[@name='order_lines']/field[@name='order_line']/list//field[@name='price_unit']" position="attributes">
                    <attribute name="readonly">parent.is_promo == True</attribute>
                </xpath>

                <xpath expr="//button[@name='%(sale.action_view_sale_advance_payment_inv)d'][1]" position="attributes">
                    <attribute name="invisible">invoice_status != 'to invoice' or is_promo == True</attribute>
                </xpath>
                <xpath expr="//button[@name='%(sale.action_view_sale_advance_payment_inv)d'][2]" position="attributes">
                    <attribute name="invisible">invoice_status != 'no' or state == 'sale' or is_promo == True</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_tree_sale_order_promotional" model="ir.ui.view">
            <field name="name">view.tree.sale.order.promotional</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="inside">
                    <field name="is_promo" invisible="1"/>
                </xpath>
                <xpath expr="//list" position="attributes">
                    <attribute name="decoration-warning">is_promo==True</attribute>
                </xpath>
            </field>
        </record>

        <record id="view_tree_sale_quote_promotional" model="ir.ui.view">
            <field name="name">view.tree.sale.quote.promotional</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_quotation_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="inside">
                    <field name="is_promo" invisible="1"/>
                </xpath>
                <xpath expr="//list" position="attributes">
                    <attribute name="decoration-warning">is_promo==True</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>