<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_internal_layout" inherit_id="web.internal_layout">
            <xpath expr="//div[@class='header']" position="replace">
            <!-- Keep this section. It removes the header -->
            <div class="header">
            <div class="row">
            </div>
            </div>
        </xpath>
    </template>

    <template id="erpc_whatsapp_client_printout_document">
        <t t-call="web.internal_layout">
            <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)" />
            <t t-set="forced_vat" t-value="doc.fiscal_position_id.foreign_vat"/> <!-- So that it appears in the footer of the report instead of the company VAT if it's set -->
            <div class="page">
                <div class="oe_structure"/>
                <!-- Is there a discount on at least one line? -->
                <t t-set="lines_to_report" t-value="doc._get_order_lines_to_report()"/>
                <t t-set="display_discount" t-value="any(l.discount for l in lines_to_report)"/>
                <div class="row">
                    <div class="col-4">
                        <span>
                            <strong>Customer Name:</strong>
                        </span>
                        <div t-field="doc.partner_id"/>
                    </div>
                    <div class="col-4">
                        <span>
                            <strong>Date:</strong>
                        </span>
                        <div t-field="doc.date_order"/>
                    </div>
                    <div class="col-4">
                        <span>
                            <strong>Total Qty:</strong>
                        </span>
                        <div t-field="doc.total_qty"/>
                    </div>
                </div>

                <table class="table table-sm o_main_table table-borderless mt-4">
                    <!-- In case we want to repeat the header, remove "display: table-row-group" -->
                    <thead style="display: table-row-group">
                        <tr>
                            <th name="th_origin" class="text-start">Origin</th>
                            <th name="th_brand" class="text-start">Category</th>
                            <th name="th_description" class="text-start">Description</th>
                            <th name="th_lot_id" class="text-start">Lot</th>
                            <th name="th_quantity" class="text-end">Qty</th>

                            <th name="th_sales_price" class="text-end">Price List</th>

                            <th name="th_retail_price" class="text-end">Retail</th>
                            <th name="th_priceunit" class="text-end">Cost</th>

                            <th name="th_subtotal" class="text-end">
                                <span groups="account.group_show_line_subtotals_tax_included">Total Price</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="sale_tbody">
                        <t t-set="current_subtotal" t-value="0"/>

                        <t t-foreach="lines_to_report" t-as="line">
                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                            <tr t-att-class="'bg-200 fw-bold o_line_section' if line.display_type == 'line_section' else 'fst-italic o_line_note' if line.display_type == 'line_note' else ''">
                                <t t-if="not line.display_type">
                                    <td name="td_origin">
                                        <span t-field="line.product_id.country_id"/>
                                    </td>
                                    <td name="td_categ">
                                        <span t-field="line.product_id.categ_id.name"/>
                                    </td>
                                    <td name="td_description">
                                        <span t-field="line.name"/>
                                    </td>
                                    <td name="td_lot_id">
                                        <span t-field="line.lot_id"/>
                                    </td>

                                    <td name="td_quantity" class="text-end">
                                        <span t-field="line.product_uom_qty"/>
                                    </td>

                                    <td name="td_sales_price" class="text-end o_price_total">
                                        <span t-field="line.sales_price" t-options='{"widget": "monetary", "display_currency": doc.pricelist_id.currency_id}'/>
                                    </td>

                                    <td name="td_retail_price" class="text-end o_price_total">
                                        <span t-field="line.product_id.retail_price" t-options='{"widget": "monetary", "display_currency": doc.pricelist_id.currency_id}'/>
                                    </td>

                                    <td name="td_priceunit" class="text-end">
                                        <span t-field="line.price_unit" t-options='{"widget": "monetary", "display_currency": doc.pricelist_id.currency_id}'/>
                                    </td>

                                    <td t-if="not line.is_downpayment" name="td_subtotal" class="text-end o_price_total">
                                        <span t-field="line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                    </td>
                                </t>
                                <t t-elif="line.display_type == 'line_section'">
                                    <td name="td_section_line" colspan="99">
                                        <span t-field="line.name"/>
                                    </td>
                                    <t t-set="current_section" t-value="line"/>
                                    <t t-set="current_subtotal" t-value="0"/>
                                </t>
                                <t t-elif="line.display_type == 'line_note'">
                                    <td name="td_note_line" colspan="99">
                                        <span t-field="line.name"/>
                                    </td>
                                </t>
                            </tr>
                            <t t-if="current_section and (line_last or doc.order_line[line_index+1].display_type == 'line_section') and not line.is_downpayment">
                                <tr class="is-subtotal text-end">
                                    <td name="td_section_subtotal" colspan="99">
                                        <strong class="mr16">Subtotal</strong>
                                        <span
                                            t-out="current_subtotal"
                                            t-options='{"widget": "monetary", "display_currency": doc.pricelist_id.currency_id}'
                                        />
                                    </td>
                                </tr>
                            </t>
                        </t>
                    </tbody>
                </table>

                <div class="clearfix" name="so_total_summary">
                    <div id="total" class="row" name="total">
                        <div t-attf-class="#{'col-6' if report_type != 'html' else 'col-sm-7 col-md-6'} ms-auto">
                            <table class="table table-sm table-borderless">
                                <!-- Tax totals -->
                                <t t-set="tax_totals" t-value="doc.tax_totals"/>
                                    <t t-set="o" t-value="doc"/>
                                    <tr class="border-black o_subtotal">
                                        <td>
                                            <strong>Total</strong>
                                        </td>

                                        <td class="text-end">
                                            <span t-att-class="oe_subtotal_footer_separator" t-field="o.amount_total"/>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>VAT LBP</strong>
                                        </td>

                                        <td class="text-end">
                                            <span t-att-class="oe_subtotal_footer_separator" t-field="o.total_vat_lbp"/>
                                        </td>
                                    </tr>

                                    <!--Total amount with all taxes-->
                                    <tr class="border-black o_total">
                                        <td>
                                            <strong>Total TTC</strong>
                                        </td>
                                        <td class="text-end">
                                            <span t-att-class="oe_subtotal_footer_separator" t-field="o.amount_total_ttc"/>
                                        </td>
                                    </tr>
                            </table>
                        </div>
                    </div>
                </div>
                <div t-if="doc.signature" class="mt-4 ml64 mr4" name="signature">
                    <div class="offset-8">
                        <strong>Signature</strong>
                    </div>
                    <div class="offset-8">
                        <img t-att-src="image_data_uri(doc.signature)" style="max-height: 4cm; max-width: 8cm;"/>
                    </div>
                    <div class="offset-8 text-center">
                        <p t-field="doc.signed_by"/>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <template id="erpc_whatsapp_client_printout">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="erpc_whatsapp_client.erpc_whatsapp_client_printout_document" t-lang="doc.partner_id.lang"/>
            </t>
        </t>
    </template>
</odoo>
