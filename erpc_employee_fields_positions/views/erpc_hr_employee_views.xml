<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="erpc_view_employee_tree" model="ir.ui.view">
        <field name="name">hr.employee.view.tree.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='department_id']" position="replace"/>
            <xpath expr="/list/field[@name='name']" position="after">
                <field name="department_id"/>
            </xpath>
            <xpath expr="//field[@name='job_id']" position="replace"/>
            <xpath expr="/list/field[@name='department_id']" position="after">
                <field name="job_id"/>
            </xpath>
            <xpath expr="/list/field[@name='company_id']" position="replace"/>
            <!-- <xpath expr="//field[@name='first_contract_date']" position="replace"/> -->

            <field name="job_id" position="after">
                <field name="device_id" optional="hide"/>
                <!-- <field name="first_contract_date" optional="hide"/> -->
                <field name="contract_end_date" optional="hide"/>
                <field name="wage" optional="hide"/>
                <field name="hourly_cost" optional="hide"/>
                <field name="ssnid" optional="hide" string="NSSF No"/>
                <field name="nssf_wage_lbp" optional="hide"/>
                <field name="nssf_wage_usd" optional="hide"/>
                <field name="is_working_spouse" optional="hide"/>
                <field name="nssf_entry_date" optional="hide"/>
                <field name="nssf_leave_date" optional="hide"/>
                <field name="registration_number" optional="hide"/>
                <field name="r3_delivery_date" optional="hide"/>
                <field name="resource_calendar_id" optional="hide"/>
                <field name="birthday" optional="hide"/>
                <field name="marital" optional="hide"/>
                <field name="children" optional="hide"/>
                <field name="visa_expire" optional="hide"/>
                <field name="work_permit_expiration_date" optional="hide"/>
                <field name="company_id"/>
            </field>

        </field>
    </record>


    <record id="view_hr_employee_inherit_form" model="ir.ui.view">
        <field name="name">hr.employee.inh.form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref='hr.view_employee_form'/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_confirm" type="object" string="Confirmed" class="oe_highlight"
                        invisible="erpc_state == 'confirm'"/>
            </xpath>

            <xpath expr="//header" position="inside">
                <field name="erpc_state"
                       widget="statusbar"
                       statusbar_visible="draft, confirm"/>
            </xpath>

            <field name="job_title" position="attributes">
                <attribute name="readonly">1</attribute>
            </field>
            <xpath expr="//group//group[1]" position="replace">
                <group>
                    <field name="contact_id" groups="base.group_multi_company"/>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="company_country_id" invisible="1"/>
                    <field name="company_country_code" invisible="1"/>
                </group>
            </xpath>


            <xpath expr="/form//field[@name='work_location_id']" position="after">
                <field name="mobile_phone" widget="phone"/>
                <field name="work_phone" widget="phone"/>
                <field name="work_email" widget="email"/>
            </xpath>


            <xpath expr="//page[@name='hr_settings']/group" position="attributes">
                <attribute name="col">1</attribute>
            </xpath>


            <xpath expr="//page[@name='work_information']" position="before">
                <page name="family_information" string="Family Information">
                    <field name="family_info_ids">
                        <list editable="bottom">
                            <field name="erpc_type" optional="show"/>
                            <field name="erpc_name" optional="show"/>
                            <field name="dob" optional="show"/>
                            <field name="dod" optional="show"/>
                            <field name="sex" optional="show"/>
                            <field name="student" optional="show"/>
                            <field name="college_uni" optional="show"/>
                            <field name="incapacity" optional="show"/>
                            <field name="family_status" optional="show"/>
                            <field name="dependant_on_employee" optional="show"/>
                        </list>
                    </field>
                </page>

                <page name="payroll_information" string="Payroll Information">
                    <group name="fam_stat">
                        <field name="sex"/>
                        <field name="marital"/>
                        <field name="is_working_spouse" invisible="marital != 'married'"/>
                        <field name="number_of_kids"/>
                        <field name="children"/>
                    </group>
                    <group>
                        <field name="ssnid"/>
                        <field name="registration_number"/>
                        <field name="has_establishment"/>
                        <field name="home_allowance" groups="hr.group_hr_user" invisible="country_id == 126"/>
                        <field name="is_nssf_social_detection" readonly="sex == 'male'"/>
                        <field name="is_representation_fees"/>

                    </group>
                    <group>
                        <field name="nssf_entry_date"/>
                        <field name="nssf_leave_date"/>
                        <field name="r3_delivery_date"/>
                    </group>
                </page>
            </xpath>


            <xpath expr="//page[@name='work_information']" position="after">
                <page name="public_work_permit" string="Work Permit">
                    <group>
                        <field name="visa_no"/>
                        <field name="permit_no"/>
                        <field name="visa_expire"/>
                        <field name="work_permit_expiration_date"/>
                        <field name="work_permit_name" invisible="1"/>
                        <field name="has_work_permit" widget="work_permit_upload" filename="work_permit_name"/>
                    </group>
                </page>
            </xpath>
            <!-- <xpath expr="//page[@name='public']/div[@id='o_work_employee_container']/div[@id='o_work_information']/group[4]"
                   position="replace"/> -->
            <xpath expr="//div[@id='o_work_information']" position="before">
                <group string="Schedule">
                    <field name="resource_calendar_id"/>
                    <field name="id" invisible="1"/>
                    <field name="tz" required="id"/>
                </group>

            </xpath>


            <xpath expr="//page[@name='personal_information']" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>

            <xpath expr="//page[@name='family_information']" position="before">
                <page name="personal_information" string="Private Information" groups="hr.group_hr_user">

                    <group col="1">
                        <group string="Private Contact" style="color: green">
                            <label for="private_street" string="Private Address"/>
                            <div class="o_address_format">
                                <field name="private_street" placeholder="Street..." class="o_address_street"/>
                                <field name="private_street2" placeholder="Street 2..." class="o_address_street"/>
                                <field name="private_city" placeholder="City" class="o_address_city"/>
                                <field name="private_state_id" class="o_address_state" placeholder="State"
                                       options="{'no_open': True, 'no_quick_create': True}"
                                       context="{'default_country_id': private_country_id}"/>
                                <field name="private_zip" placeholder="ZIP" class="o_address_zip"/>
                                <field name="private_country_id" placeholder="Country" class="o_address_country"
                                       options='{"no_open": True, "no_create": True}'/>
                            </div>
                            <field name="private_email" string="Email"/>
                            <field name="private_phone" string="Phone"/>
                            <field name="bank_account_ids" context="{'default_partner_id': work_contact_id}"
                                   options="{'no_quick_create': True}" readonly="not id" widget="many2many_tags"/>
                            <field name="lang" string="Language"/>
                            <label for="km_home_work"/>
                            <div class="o_row" name="div_km_home_work">
                                <field name="km_home_work" class="o_hr_narrow_field"/>
                                <span>Km</span>
                            </div>
                            <field name="private_car_plate"/>
                            <field name="spouse_complete_name" invisible="marital not in ['married', 'cohabitant']"/>
                            <field name="spouse_birthdate" invisible="marital not in ['married', 'cohabitant']"/>
                        </group>
                        <group string="Citizenship">
                            <field name="country_id" options='{"no_open": True, "no_create": True}'/>
                            <field name="identification_id"/>
                            <field name="passport_id"/>
                            <field name="sex"/>
                            <field name="birthday"/>
                            <field name="place_of_birth"/>
                            <field name="country_of_birth"/>
                        </group>
                        <group string="Education">
                            <field name="certificate"/>
                            <field name="study_field"/>
                            <field name="study_school"/>
                        </group>
                        <group string="Emergency Information" name="emergency_info">
                            <field name="emergency_contact"/>
                            <field name="emergency_phone" class="o_force_ltr"/>
                        </group>
                    </group>
                </page>

            </xpath>

        </field>
    </record>


</odoo>
