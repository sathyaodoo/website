<odoo>
    <data>
        <template id="yokohama_invoice_temp_three">
            <t t-call="web.html_container">
                <t t-call="web.basic_layout">
                    <t t-foreach="docs" t-as="o">
                        <div class="row">
                            <div t-attf-style="margin-left:500px;margin-top:135px;position: absolute;font-size:26px};" class="col-8">
                                <span style="font-weight:bold;text-transform: capitalize" t-esc="o.partner_id.name"/>
                            </div>

                            <div t-attf-style="margin-left:500px;margin-top:170px;position: absolute;font-size:20px};" class="col-8">
                                <span style="font-weight:bold;text-transform: capitalize" t-esc="o.partner_id.city"/>
                                -
                                <span style="font-weight:bold;text-transform: capitalize" t-esc="o.partner_id.zip"/>
                                -
                                <span style="font-weight:bold;text-transform: capitalize" t-esc="o.partner_id.state_id.name"/>
                                <br/>
                                <span style="font-weight:bold;text-transform: capitalize" t-esc="o.partner_id.street"/>

                                <br/>
                                <span style="font-weight:bold;text-transform: capitalize" t-esc="o.partner_id.phone"/>
                                <br/>
                                <span style="font-weight:bold;text-transform: capitalize" t-esc="o.partner_id.vat"/>
                            </div>

                            <div t-attf-style="margin-left:1135px;margin-top:145px;position: absolute;font-size:18px;" class="col-8">
                                <span style="font-weight:bold;text-transform: capitalize" t-esc="o.name"/>
                                <br/>
                                <span style="font-weight:bold;text-transform: capitalize" t-esc="o.invoice_date"/>
                            </div>

                            <div t-attf-style="margin-left:1175px;margin-top:225px;position: absolute;font-size:18px;" class="col-8">
                                <span style="font-weight:bold;text-transform: capitalize;font-size:18px;" t-esc="o.currency_id.name"/>
                                <br/>
                                <span style="font-weight:bold;text-transform: capitalize" t-esc="o.invoice_date_due"/>
                            </div>

                            <div t-attf-style="margin-left:15px;margin-top:317px;position: absolute;font-size:20px;">
                                <style type="text/css">
                                    .tg {
                                        border: 0px hidden transparent;
                                        table-layout: fixed;
                                        width: 1324px;
                                        height: 285px;
                                    }
                                    .tg td, .tg th {
                                        border: none;
                                        font-family: Arial, sans-serif;
                                        font-size: 20px;
                                        font-weight: normal;
                                        padding: 0;
                                        margin: 0;
                                    }
                                    .tg .tg-8jgo {
                                        text-align: center;
                                        vertical-align: top;
                                    }
                                </style>
                                <table class="tg">
                                    <colgroup>
                                        <col style="width: 145px"/>
                                        <col style="width: 370px"/>
                                        <col style="width: 70px"/>
                                        <col style="width: 106px"/>
                                        <col style="width: 124px"/>
                                        <col style="width: 123px"/>
                                        <col style="width: 113px"/>
                                        <col style="width: 124px"/>
                                        <col style="width: 170px"/>
                                    </colgroup>
                                    <thead>
                                        <tr>
                                            <td class="tg-8jgo">
                                                <span style="font-weight:400;font-style:normal;font-weight:bold">
                                                    Category
                                                </span>
                                            </td>
                                            <td class="tg-8jgo">
                                                <span style="font-weight:400;font-style:normal;font-weight:bold">
                                                    Description
                                                </span>
                                            </td>
                                            <td class="tg-8jgo">
                                                <span style="font-weight:400;font-style:normal;font-weight:bold">
                                                    LOT
                                                </span>
                                            </td>
                                            <td class="tg-8jgo">
                                                <span style="font-weight:400;font-style:normal;font-weight:bold">
                                                    Quantity
                                                </span>
                                            </td>
                                            <td class="tg-8jgo">
                                                <span style="font-weight:400;font-style:normal;font-weight:bold">
                                                    Price List
                                                </span>
                                            </td>
                                            <td class="tg-8jgo">
                                                <span style="font-weight:400;font-style:normal;font-weight:bold">
                                                    Client Discount
                                                </span>
                                            </td>
                                            <td class="tg-8jgo">
                                                <span style="font-weight:400;font-style:normal;font-weight:bold">
                                                    Add Discount
                                                </span>
                                            </td>
                                            <td class="tg-8jgo">
                                                <span style="font-weight:400;font-style:normal;font-weight:bold">
                                                    Final U.P
                                                </span>
                                            </td>
                                            <td class="tg-8jgo">
                                                <span style="font-weight:400;font-style:normal;font-weight:bold">
                                                    Total
                                                </span>
                                            </td>
                                        </tr>
                                    </thead>
                                    <tbody class="invoice_tbody">
                                        <t t-set="current_subtotal" t-value="0"/>
                                        <t t-set="sum_quantity" t-value="0"/>
                                        <t t-set="lines" t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)"/>

                                        <t t-foreach="lines" t-as="line">
                                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                            <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                                            <tr style="height:10px;" t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                                <t t-if="line.display_type" name="account_invoice_line_accountable">
                                                    <td>
                                                        <span t-field="line.product_id.categ_id.name"/>
                                                    </td>
                                                    <td name="account_invoice_line_name">
                                                        <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                                        <span t-field="line.aditional_note"/>
                                                    </td>
                                                    <td class="text-center">
                                                        <span t-field="line.sale_line_ids.lot_id.name"/>
                                                    </td>
                                                    <td class="text-center">
                                                        <span t-esc="round(line.quantity)"/>
                                                        <!--                                                    <span t-field="line.product_uom_id" groups="uom.group_uom"/>-->
                                                        <t t-set="sum_quantity" t-value="sum_quantity + line.quantity"/>
                                                    </td>
                                                    <td class="text-center">
                                                        <span t-esc="line.price_after_discount" t-options="{'widget': 'monetary', 'display_currency': line.currency_id}"/>
                                                    </td>

                                                    <td class="text-left">
<!--                                                        <span t-esc="line.price_list_id.discount_string"/>-->
                                                    </td>
                                                    <t t-if="line.discount">
                                                        <td class="text-center">
                                                            <span class="text-left" t-field="line.discount"/>%
<!--                                                            <span class="text-left" t-esc="round(line.discount)"/>-->
                                                        </td>
                                                    </t>
                                                    <t t-else="">
                                                        <td class="text-center">

                                                        </td>

                                                    </t>

                                                    <td t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                                        <span class="text-nowrap" t-field="line.final_price" t-options="{'widget': 'monetary', 'display_currency': line.currency_id}"/>
                                                    </td>
                                                    <td class="text-left o_price_total">
                                                        <span class="text-left" t-field="line.price_total"/>
                                                    </td>
                                                </t>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div t-attf-style="margin-left:0px;margin-top:800px;position: absolute;font-size:20px};" class="col-8">
                            <span t-esc="o.amount_total_words"/>
                        </div>
                        <div t-attf-style="margin-left:850px;margin-top:800px;position: absolute;font-size:20px};" class="col-8">
                            <span t-esc="round(sum_quantity)"/>
                        </div>
                        <div t-attf-style="margin-left:580px;margin-top:880px;position: absolute;font-size:20px};" class="col-8">
                            <table style="border-collapse: collapse; width:400px; height: 90px; border: 0px hidden transparent;">
                                <tbody>
                                    <tr style="height: 18px;">
                                        <td style="width: 35%; height: 18px;font-size:20px">VAT LBP</td>
                                        <td style="width: 65%; height: 18px;font-size:20px">
                                            <t t-if="o.vat_move_id">
                                                <span class="text-left" t-field="o.vat_move_id.amount_residual"/>
                                            </t>
                                            <t t-else="">
                                                <span class="text-left">ل.ل 0.00</span>
                                            </t>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div t-attf-style="margin-left:975px; margin-top:795px; position: absolute; font-size:20px};" class="col-8">
                            <table style="border-collapse: collapse; width:400px; height: 40px; border: 0px hidden transparent;" border="1">
                                <tbody>
                                    <tr style="height: 20px;">
                                        <td style="width: 60%; height: 20px;font-size:20px">Sub - Total</td>
                                        <td style="width: 40%; height: 20px;font-size:20px">
                                            <span class="text-left" t-field="o.amount_untaxed"/>
                                        </td>
                                    </tr>
                                    <tr style="height: 15px;margin-top:5px">
                                        <td style="width: 60%; height: 15px;font-size:20px">Additional %</td>
                                        <td style="width: 40%; height: 15px;font-size:20px">
                                            <span class="text-left" t-field="o.discount_rate"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div t-attf-style="margin-left:975px; margin-top:863px; position: absolute; font-size:20px};" class="col-8">
                            <table style="border-collapse: collapse; width:400px; height: 40px; border: 0px hidden transparent;" border="1">
                                <tbody>
                                    <tr style="height: 18px;">
                                        <td style="width: 60%; height: 18px;font-size:20px">Total Bef V.A.T</td>
                                        <td style="width: 40%; height: 18px;font-size:20px">
                                            <span class="text-left" t-field="o.amount_untaxed"/>
                                        </td>
                                    </tr>
                                    <tr style="height: 18px;">
                                        <!--<td style="width: 60%; height: 18px;font-size:20px">V.A.T. 11%</td>-->
                                        <!--<td style="width: 40%; height: 18px;font-size:20px">-->
                                        <!--    <span class="text-left" t-field="o.vat_move_id.amount_residual"/>-->
                                        <!--</td>-->
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div t-attf-style="margin-left:975px; margin-top:930px; position: absolute; font-size:20px};" class="col-8">
                            <table style="border-collapse: collapse; width:400px; height: 10px; border: 0px hidden transparent;" border="0">
                                <tbody>
                                    <tr style="height: 18px;">
                                        <td style="width: 60%;font-size:21px;font-weight:600;">Net Total</td>
                                        <td style="width: 40%;font-size:21px;font-weight:600;">
                                            <span class="text-left" t-field="o.amount_total"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div t-attf-style="margin-left:975px; margin-top:990px; position: absolute; font-size:20px};" class="col-8">
                            <table style="border-collapse: collapse; width:400px; height: 10px; border: 0px hidden transparent;" border="0">
                                <tbody>
                                    <tr style="height: 24px;">
                                        <td style="width: 60%;font-size:20px">Current Balance</td>
                                        <td style="width: 40%;font-size:20px">
                                            <span class="text-left" t-field="o.total_due"/>
                                        </td>
                                    </tr>
                                    <!--<tr style="height: 18px;">-->
                                    <!--    <td style="width: 60%;font-size:20px">Old Balance</td>-->
                                    <!--    <td style="width: 40%;font-size:20px">-->
                                    <!--        <span class="text-left" t-field="o.due_draft_invoice"/>-->
                                    <!--    </td>-->
                                    <!--</tr>-->
                                </tbody>
                            </table>
                        </div>

                        <div t-attf-style="margin-left:63px;margin-top:853px;position: absolute;font-size:20px;};" class="col-8">
                            <table style="border-collapse: collapse; height: 10px; border: 0px hidden transparent;" border="0">
                                <tbody>
                                    <tr style="height: 18px;">
                                        <td style="width: 80%;font-size:20px;">
                                            <span class="text-left" t-field="o.narration"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                        <div t-attf-style="margin-left:975px; margin-top:1115px; position: absolute; font-size:20px};" class="col-8">
                            <table style="border-collapse: collapse; width:400px; height: 10px; border: 0px hidden transparent;" border="0">
                                <tbody>
                                    <tr style="height: 18px;">
                                        <td style="width: 25%;font-size:20px"/>
                                        <td style="width: 75%;font-size:20px">
                                            <span class="text-left" t-field="o.driver_id.name"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
<!--                        <div t-attf-style="margin-left:575px; margin-top:1115px; position: absolute; font-size:20px};" class="col-8">-->
<!--                            <table style="border-collapse: collapse; width:400px; height: 10px; border: 0px hidden transparent;" border="0">-->
<!--                                <tbody>-->
<!--                                    <tr style="height: 18px;">-->
<!--                                        <td style="width: 25%;font-size:20px;">-->
<!--                                            <span class="text-left">Collector:</span>-->
<!--                                        </td>-->
<!--                                        <td style="width: 75%;font-size:20px;">-->
<!--                                            <span class="text-left" t-field="o.collector.name"/>-->
<!--                                        </td>-->
<!--                                    </tr>-->
<!--                                </tbody>-->
<!--                            </table>-->
<!--                        </div>-->
                    </t>
                </t>
            </t>
        </template>

        <record id="yoko_invoice_template_report_new_three" model="ir.actions.report">
            <field name="name">Invoice JP</field>
            <field name="model">account.move</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">yoko_customization.yokohama_invoice_temp_three</field>
            <field name="report_file">yoko_customization.yokohama_invoice_temp_three</field>
            <field name="print_report_name">'Invoice Template'</field>
            <field name="paperformat_id" ref="yoko_customization.erpc_yoko_letter_paperformat"/>

            <field name="binding_model_id" ref="account.model_account_move"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>