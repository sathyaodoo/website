<odoo>
    <data>

        <template id="yokohama_invoice_temp">
            <t t-call="web.html_container">
                <t t-call="web.basic_layout">
                    <t t-foreach="docs" t-as="o">
<!--                        <div class="row"-->
<!--                             t-attf-style="background-image:url('yoko_invoice_template/static/img/yoko_invoice.jpg'); background-size:390mm 253mm; width:390mm; height:253mm;font-size:13px">-->
                        <div class="row">
                            <div t-attf-style="margin-left:755px;margin-top:155px;position: absolute;font-size:26px};"
                                 class="col-8">
                                <span style="font-weight:bold;text-transform: capitalize"
                                      t-esc="o.partner_id.name"/>

                            </div>

                            <div t-attf-style="margin-left:755px;margin-top:190px;position: absolute;font-size:20px};"
                                 class="col-8">
                                <span style="font-weight:bold;text-transform: capitalize" t-esc="o.partner_id.city"/>
                                -
                                <span style="font-weight:bold;text-transform: capitalize" t-esc="o.partner_id.zip"/>
                                -
                                <span style="font-weight:bold;text-transform: capitalize"
                                      t-esc="o.partner_id.state_id.name"/>
                                <br/>
                                <span style="font-weight:bold;text-transform: capitalize" t-esc="o.partner_id.street"/>

                                <br/>
                                <span style="font-weight:bold;text-transform: capitalize" t-esc="o.partner_id.phone"/>
                                <br/>
                                <span style="font-weight:bold;text-transform: capitalize" t-esc="o.partner_id.vat"/>
                            </div>

                            <div t-attf-style="margin-left:1370px;margin-top:165px;position: absolute;font-size:18px;"
                                 class="col-8">
                                <span style="font-weight:bold;text-transform: capitalize"
                                      t-esc="o.name"/>
                                <br></br>
                                <span style="font-weight:bold;text-transform: capitalize"
                                      t-esc="o.invoice_date"/>
                            </div>

                            <div t-attf-style="margin-left:1405px;margin-top:255px;position: absolute;font-size:18px;"
                                 class="col-8">

                                <span style="font-weight:bold;text-transform: capitalize;font-size:18px;"
                                      t-esc="o.currency_id.name"/>
                                <br></br>
                                <span style="font-weight:bold;text-transform: capitalize"
                                      t-esc="o.invoice_date_due"/>
                            </div>


                            <div t-attf-style="margin-left:265px;margin-top:343px;position: absolute;font-size:20px;">
                            <style type="text/css">
                                .tg {}
                                .tg td{border-color:#ffffff;border-style:none;border-width:0px;font-family:Arial,
                                sans-serif;font-size:20px;
                                overflow:hidden;padding:0px 0px;word-break:normal;}
                                .tg th{border-color:#ffffff;border-style:none;border-width:0px;font-family:Arial,
                                sans-serif;font-size:20px;
                                font-weight:normal;overflow:hidden;padding:0px 0px;word-break:normal;}
                                .tg .tg-8jgo{border-color:#ffffff;text-align:center;vertical-align:top}
                            </style>
                            <table class="tg" style="undefined;table-layout: fixed; width: 1324px;  height: 285px;">
                                <colgroup>
                                    <col style="width: 145px"/>
                                    <col style="width: 388px"/>
                                    <col style="width: 65px"/>
                                    <col style="width: 106px"/>
                                    <col style="width: 124px"/>
                                    <col style="width: 123px"/>
                                    <col style="width: 113px"/>
                                    <col style="width: 124px"/>
                                    <col style="width: 170px"/>
                                </colgroup>
                                <thead>
                                    <tr>
                                        <td class="tg-8jgo">
                                            <span style="font-weight:400;font-style:normal;font-weight:bold">Brand</span>
                                        </td>
                                        <td class="tg-8jgo">
                                            <span style="font-weight:400;font-style:normal;font-weight:bold">Description</span>
                                        </td>
                                        <td class="tg-8jgo">
                                            <span style="font-weight:400;font-style:normal;font-weight:bold">WHS</span>
                                        </td>
                                        <td class="tg-8jgo">
                                            <span style="font-weight:400;font-style:normal;font-weight:bold">Quantity</span>
                                        </td>
                                        <td class="tg-8jgo">
                                            <span style="font-weight:400;font-style:normal;font-weight:bold">Price List</span>
                                        </td>
                                        <td class="tg-8jgo">
                                            <span style="font-weight:400;font-style:normal;font-weight:bold">Client Discount</span>
                                        </td>
                                        <td class="tg-8jgo">
                                            <span style="font-weight:400;font-style:normal;font-weight:bold">Add Discount</span>
                                        </td>
                                        <td class="tg-8jgo">
                                            <span style="font-weight:400;font-style:normal;font-weight:bold">Final U.P</span>
                                        </td>
                                        <td class="tg-8jgo">
                                            <span style="font-weight:400;font-style:normal;font-weight:bold">Total</span>
                                        </td>
                                    </tr>
                                </thead>
                                <tbody class="invoice_tbody">
                                    <t t-set="current_subtotal" t-value="0"/>
                                    <t t-set="sum_quantity" t-value="0"/>
                                    <t t-set="lines"
                                       t-value="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)"/>

                                    <t t-foreach="lines" t-as="line">
                                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal"
                                           groups="account.group_show_line_subtotals_tax_excluded"/>
                                        <t t-set="current_subtotal" t-value="current_subtotal + line.price_total"
                                           groups="account.group_show_line_subtotals_tax_included"/>

                                        <tr style="height:10px;" t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                            <t t-if="not line.display_type" name="account_invoice_line_accountable">
                                                <td>
                                                    <span t-field="line.product_id.brand_id.name"/>
                                                </td>
                                                <td name="account_invoice_line_name"><span t-field="line.name" t-options="{'widget': 'text'}"/> <span t-field="line.aditional_note"/>
                                                </td>
                                                <td class="text-center">
                                                    <span t-field="o.warehouse_id.code"/>
                                                </td>
                                                <td class="text-center">
                                                    <span t-esc="round(line.quantity)"/>
<!--                                                    <span t-field="line.product_uom_id" groups="uom.group_uom"/>-->
                                                    <t t-set="sum_quantity" t-value="sum_quantity + line.quantity"/>
                                                </td>
                                                <td class="text-center">
                                                    <span t-esc="line.price_after_discount"/>
                                                    </td>

                                                <td class="text-left">
                                                    <span t-esc="line.price_list_id.discount_string"/>
                                                </td>
                                                <t t-if="line.discount">
                                                    <td class="text-center">
                                                        <span class="text-left" t-field="line.discount"/>
<!--                                                        <span class="text-left" t-esc="round(line.discount)"/>-->
                                                    </td>
                                                </t>
                                                <t t-else="">
                                                    <td class="text-center">

                                                    </td>

                                                </t>

                                                <td t-attf-class="text-center {{ 'd-none d-md-table-cell' if report_type == 'html' else '' }}">
                                                    <span class="text-nowrap" t-field="line.price_unit"/>%
                                                </td>
                                                <td class="text-left o_price_total">
                                                    <span class="text-nowrap" t-field="line.price_subtotal"
                                                          groups="account.group_show_line_subtotals_tax_excluded"/>
                                                    <span class="text-left" t-field="line.price_total"
                                                          groups="account.group_show_line_subtotals_tax_included"/>
                                                </td>
                                            </t>

                                        </tr>
                                    </t>
                                </tbody>

                            </table>
                            </div>


                        </div>
                        <!--                        <div  class="row" >-->
                        <!--                        </div>-->
                        <div t-attf-style="margin-left:265px;margin-top:832px;position: absolute;font-size:20px};"
                             class="col-8">
                            <span t-esc="o.amount_total_words"/>
                        </div>
                        <div t-attf-style="margin-left:1100px;margin-top:832px;position: absolute;font-size:20px};"
                             class="col-8">
                            <span t-esc="round(sum_quantity)"/>
                        </div>
                        <div t-attf-style="margin-left:800px;margin-top:880px;position: absolute;font-size:20px};"
                             class="col-8">
                            <table style="border-collapse: collapse; width:400px; height: 90px;" border="1">
                                <tbody>
                                    <tr style="height: 18px;">
                                        <td style="width: 55%; height: 18px;font-size:20px">VAT LBP</td>
                                        <td style="width: 45%; height: 18px;font-size:20px">
                                            <span class="text-left" t-field="o.taxed_custom_amount"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>


                        </div>

                        <div t-attf-style="margin-left:1200px;margin-top:828px;position: absolute;font-size:20px};"
                             class="col-8">
                            <table style="border-collapse: collapse; width:400px; height: 40px;"
                               border="1">
                            <tbody>
                                <tr style="height: 20px;">
                                    <td style="width: 55%; height: 20px;font-size:20px">Sub - Total</td>
                                    <td style="width: 45%; height: 20px;font-size:20px"><span class="text-left" t-field="o.amount_untaxed"/></td>
                                </tr>
                                <tr style="height: 15px;margin-top:5px">
                                    <td style="width: 55%; height: 15px;font-size:20px">Additional %</td>
                                    <td style="width: 45%; height: 15px;font-size:20px"><span class="text-left" t-field="o.discount_rate"/></td>
                                </tr>
                            </tbody>
                        </table>
                        </div>

                        <div t-attf-style="margin-left:1200px;margin-top:915px;position: absolute;font-size:20px};"
                             class="col-8">
                            <table style="border-collapse: collapse; width:400px; height: 40px;"
                               border="1">
                            <tbody>
                                <tr style="height: 18px;">
                                    <td style="width: 55%; height: 18px;font-size:20px">Total Bef V.A.T</td>
                                    <td style="width: 45%; height: 18px;font-size:20px"><span class="text-left" t-field="o.amount_untaxed"/></td>
                                </tr>
                                <tr style="height: 18px;">
                                    <td style="width: 55%; height: 18px;font-size:20px">V.A.T. 11%</td>
                                    <td style="width: 45%; height: 18px;font-size:20px"><span class="text-left" t-field="o.amount_tax"/></td>
                                </tr>
                            </tbody>
                        </table>
                        </div>

                        <div t-attf-style="margin-left:1200px;margin-top:1010px;position: absolute;font-size:20px};"
                             class="col-8">
                            <table style="border-collapse: collapse; width:400px; height: 10px;"
                                   border="0">
                                <tbody>
                                    <tr style="height: 18px;">
                                        <td style="width: 55%;font-size:20px">Net Total</td>
                                        <td style="width: 45%;font-size:20px">
                                            <span class="text-left" t-field="o.amount_total"/>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </t>
                </t>
            </t>
        </template>
    </data>
</odoo>