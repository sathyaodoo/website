<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="erpc_view_order_form" model="ir.ui.view">
            <field name="name">contacts_yokohama_dev.sale.order.form</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="before">
                    <field name="parent_id" readonly="state not in ('draft', 'sent')"/>
                </xpath>

                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="domain">
                        [('is_driver', '=', False)]
                    </attribute>
                    <attribute name="options">
                        {'no_edit': True, 'no_create': True}
                    </attribute>
                    <attribute name="invisible">parent_id</attribute>
                </xpath>

                <xpath expr="//field[@name='order_line']/list/field[@name='name']" position="after">
                    <field name="aditional_note"/>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='order_lines']/field[@name='order_line']/list[1]/field[@name='product_id']"
                       position="attributes">
                    <attribute name="options">
                        {"no_create": true, "no_open": true}
                    </attribute>
                </xpath>
                <!--                <xpath expr="//notebook//page//group//group[@name='sale_shipping']" position="attributes">-->
                <!--                    <attribute name="invisible">1</attribute>-->
                <!--                </xpath>-->
                <xpath expr="//field[@name='partner_invoice_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='partner_shipping_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <field name="partner_id" position="after">
                    <field invisible="1" name="second_currency_id" readonly="state in ('sale')"/>
                    <field name="warehouse_id"/>
                    <field name="delivery_term" readonly="state not in ('draft', 'sent')"/>
                </field>
                <xpath expr="//group[@name='sale_total']" position="after">
                    <group class="oe_subtotal_footer oe_right" colspan="2" name="sale_total_qty"
                           string="Total Quantity">
                        <field name="total_qty"/>
                    </group>
<!--                    <xpath expr="//field[@name='tax_totals']" position="after">-->
<!--                        <label for="total_qty"/>-->
<!--                        <div class="text-nowrap">-->
<!--                            <field name="total_qty" class="oe_inline"/>-->
<!--                        </div>-->
<!--                    </xpath>-->
                    <group class="oe_subtotal_footer oe_right" colspan="2" name="sale_bmr" string="LBP">
                        <field class="oe_inline" invisible="1" name="in_lbp_currency"/>
                        <field invisible="in_lbp_currency == True" name="untaxed_custom_amount"/>
                        <field invisible="in_lbp_currency == True" name="taxed_custom_amount"/>
                    </group>
                    <div class="clearfix"/>
                </xpath>
                <field name="payment_term_id" position="after">
                    <field name="currency_id"/>
                    <field name="current_rate" readonly="1"/>
                    <!--                    <field name="total_qty"/>-->
                    <field invisible="1" name="discount_pricelists"/>
                </field>
                <field name="payment_term_id" position="attributes">
                    <attribute name="readonly">state not in ('draft', 'sent')</attribute>
                </field>
                <field name="user_id" position="attributes">
                    <attribute name="readonly">state not in ('draft', 'sent')</attribute>
                </field>
                <field name="team_id" position="attributes">
                    <attribute name="readonly">state not in ('draft', 'sent')</attribute>
                </field>

                <xpath expr="//field[@name='order_line']/list/field[@name='price_unit']" position="before">
                    <field name="sales_price" widget="monetary"/>
                    <field name="can_edit_discount" optional="hide" column_invisible="True"/>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='order_lines']/field[@name='order_line']/list[1]/field[@name='discount']"
                       position="attributes">
                    <attribute name="readonly">can_edit_discount == False</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='order_lines']/field[@name='order_line']/list[1]/field[@name='product_id']"
                       position="attributes">
                    <attribute name="width">100px</attribute>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='order_lines']/field[@name='order_line']/list[1]/field[@name='name']"
                       position="attributes">
                    <attribute name="width">100px</attribute>
                </xpath>
                <xpath expr="//field[@name='parent_id']" position="after">
                    <field name="partner_id"
                           domain="[('is_driver', '=', False),('parent_id', '=', parent_id)]"
                           widget="res_partner_many2one" invisible="not parent_id"
                           context="{'res_partner_search_mode': 'customer', 'show_address': 1, 'show_vat': True}"
                           placeholder="Type to find a customer..." readonly="state in ['cancel', 'sale']"/>
                </xpath>
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='order_lines']/div[@name='so_button_below_order_lines']/button[@name='action_open_delivery_wizard']"
                       position="attributes">
                    <attribute name="invisible">True</attribute>
                </xpath>
<!--                TODO GR: to check later if we need to hide it-->
<!--                <xpath expr="//form[1]/sheet[1]/group[@name='sale_header']/group[@name='order_details']/div[3]/field[@name='pricelist_id']" position="attributes">-->
<!--                    <attribute name="invisible">True</attribute>-->
<!--                </xpath>-->
                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='order_lines']/field[@name='order_line']/list[1]/field[@name='price_subtotal']"
                       position="attributes">
                    <attribute name="column_invisible">True</attribute>
                    <attribute name="invisible">False</attribute>
                </xpath>
            </field>

        </record>

