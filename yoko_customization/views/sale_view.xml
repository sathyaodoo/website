                    <field name="commitment_date" readonly="state in ('done', 'cancel')"/>
                </xpath>
                <!--                <xpath expr="//field[@name='name']" position="before">-->
                <!--                    <field decoration-danger="quotation_type == 'rfq'" decoration-info="quotation_type == 'quotation'"-->
