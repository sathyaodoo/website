<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="contacts_yokohama_dev_view_move_form" model="ir.ui.view">
            <field name="name">contacts_yokohama_dev.account.move.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="domain">[('is_driver', '=', False)]</attribute>

                    <attribute name="options">{'no_edit': True, 'no_create': True}</attribute>
                </xpath>
            </field>
        </record>

        <record id="account_move_view_tree_contacts_fields" model="ir.ui.view">
            <field name="name">account.move.view.tree.contacts.fields</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_invoice_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_date']" position="before">
<!--                    <field name="kaza_id"/>-->
<!--                    <field name="city_id"/>-->
                    <field name="state_id"/>
                </xpath>
                <xpath expr="//field[@name='invoice_user_id']" position="after">
                    <field name="create_uid" string="Created By"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
