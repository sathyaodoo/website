    <record id="parent_company_view_form" model="ir.ui.view">
        <field name="name">parent_company.view.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='parent_id']" position="attributes">
                <attribute name="invisible">(is_company == True and is_company == False) or parent_id == False and company_name != False and company_name != ''</attribute>
            </xpath>
<!--            <xpath expr="//page[@name='sales_purchases']/group/group[1]/field[@name='user_id']" position="attributes">-->
<!--                <attribute name="required">1</attribute>-->
<!--            </xpath>-->
            <xpath expr="//field[@name='phone']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
            <xpath expr="//field[@name='street']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
            <xpath expr="//field[@name='state_id']" position="attributes">
                <attribute name="required">1</attribute>
            </xpath>
<!--            <xpath expr="//field[@name='property_payment_term_id']" position="attributes">-->
<!--                <attribute name="required">1</attribute>-->
<!--            </xpath>-->
<!--            <xpath expr="//field[@name='category_id']" position="attributes">-->
<!--                <attribute name="required">1</attribute>-->
<!--            </xpath>-->
            <xpath expr="//field[@name='website']" position="after">
                <field name="second_phone"/>
                <field name="birthdate"/>
<!--                <field name="customer_category_id"/>-->
            </xpath>
        </field>
    </record>
    <record id="view_res_partner_filter" model="ir.ui.view">
        <field name="name">partner_manual_rank.view_partner_filter</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <field name="parent_id" position="after">
                <field name="id" string="ID"/>
<!--                <field name="is_customer"/>-->
<!--                <field name="is_supplier"/>-->
            </field>
        </field>
    </record>
