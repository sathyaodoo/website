        <record id="account_move_search_filter" model="ir.ui.view">
            <field name="name">account.move.search</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_invoice_filter"/>
            <field name="arch" type="xml">
                <search>
                    <filter domain="[('state', '=', 'posted'),('payment_state', '=', 'not_paid')]" name="status_filter" string="Posted and not paid"/>
                    <group>
                        <filter context="{'group_by':'partner_id'}" name="group_by_partner" string="Customer"/>
                        <filter context="{'group_by':'parent_company_id'}" name="group_by_parent_company" string="Parent Company"/>
                    </group>
                </search>
                <!--                <group expand="0" string="Group By">-->
                <!--                    <filter context="{'group_by':'collector'}" name="group_by_collector" string="Collector"/>-->
                <!--                </group>-->
            </field>
        </record>

        <record id="custom_account_invoice_filter" model="ir.ui.view">
            <field name="name">account.invoice.select.custom</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_invoice_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search" position="inside">
                    <field filter_domain="[('line_ids.product_id', 'ilike', self)]" name="invoice_line_ids" string="Product"/>
                </xpath>
            </field>
        </record>
