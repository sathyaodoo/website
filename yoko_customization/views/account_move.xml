    <data>
        <!-- Inherit Form View to Modify it -->
        <record id="view_order_form_inherittt" model="ir.ui.view">
            <field name="name">account.move.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='partner_id']" position="after">
                    <!--                    <field name="user_is_super" optional="show"/>-->
                    <field name="can_edit_discount"/>
                </xpath>
                <!-- <xpath expr="//field[@name='line_ids']/list/field[@name='quantity']" position="after">
                    <field name="price_after_discount" optional="hide" widget="monetary"/>
                </xpath> -->
                <xpath expr="/form/sheet/notebook/page[@id='aml_tab']/field[@name='line_ids']/list//field[@name='credit']" position="after">
                    <field name="price_after_discount" optional="hide" widget="monetary"/>
                </xpath>
                <!--                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[1]/field[@name='invoice_line_ids']/tree[1]/field[@name='price_unit']"-->
                <!-- position="attributes">-->
                <!--                    <attribute name="readonly">parent.user_is_super != True</attribute>-->
                <!--                </xpath>-->
                <xpath expr="/form/sheet/notebook/page[@id='aml_tab']/field[@name='line_ids']/list//field[@name='discount_amount_currency']" position="attributes">
                    <attribute name="readonly">parent.can_edit_discount == False</attribute>
                    <attribute name="optional">show</attribute>
                </xpath>
                <xpath expr="//field[@name='partner_shipping_id']" position="before">
                    <!--                    TODO GR: to make driver_id readonly="1"-->
                    <field invisible="move_type not in 'out_invoice'" name="driver_id" required="move_type in 'out_invoice'" options="{'no_create': True}" readonly="0"/>
                    <!--                    <field invisible="move_type not in 'out_invoice'" name="delivery_term" readonly="1"/>-->
                </xpath>
                <!--                <xpath expr="//group[@id='header_right_group']" position="inside">-->
                <!--                    <field name="total_qty"/>-->
                <!--                </xpath>-->
                <xpath expr="//field[@name='delivery_date']" position="replace"/>
                <xpath expr="//field[@name='partner_shipping_id']" position="attributes">
                    <attribute name="invisible">1</attribute>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field invisible="1" name="second_currency_id" readonly="state in ('sales')"/>
                    <!--                    <field invisible="1" name="invoice_from_sale"/>-->
                    <field invisible="1" name="total_due"/>
                    <field invisible="1" name="due_draft_invoice"/>
                    <field invisible="1" name="due_confirm_invoice"/>
                </xpath>
                <!--                <xpath expr="//field[@name='invoice_outstanding_credits_debits_widget']" position="after">-->
                <!--                    <field invisible="1" name="in_lbp_currency"/>-->
                <!--                    <label for="in_lbp_currency" invisible="in_lbp_currency == True" string="BMR"-->
                <!-- style="font-size:20px"/>-->
                <!--                    <field invisible="in_lbp_currency == True" name="untaxed_custom_amount"/>-->
                <!--                    <field invisible="in_lbp_currency == True" name="taxed_custom_amount"/>-->
                <!--                </xpath>-->

                <xpath expr="//group[@class='oe_subtotal_footer']" position="inside">
                    <field name="in_lbp_currency" invisible="1"/>
                    <!-- <label for="in_lbp_currency" invisible="in_lbp_currency == True" string="LBP"/> -->
                    <!--                    TODO GR: to add taxed_custom_amount-->
                    <field name="untaxed_custom_amount" class="oe_subtotal_footer_separator" invisible="in_lbp_currency == True" string="Untaxed LBP"/>
                    <!--                    <field name="taxed_custom_amount" class="oe_subtotal_footer_separator" invisible="in_lbp_currency == True" string="Amount LBP"/>-->
                    <field name="taxed_custom_amount" class="oe_subtotal_footer_separator" invisible="in_lbp_currency == True"/>


                </xpath>

                <xpath expr="//field[@name='invoice_origin']" position="attributes">
                    <attribute name="invisible">0</attribute>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="attributes">
                    <attribute name="required">move_type in 'out_invoice'</attribute>
                </xpath>
                <xpath expr="//div[@name='journal_div']" position="after">
                    <field name="current_rate" readonly="True"/>
                    <field name="posted_before"/>

                </xpath>

                <xpath expr="/form/sheet/notebook/page[@id='aml_tab']/field[@name='line_ids']/list//field[@name='discount_amount_currency']" position="after">
                    <field name="final_price" optional="hide"/>
                    <field name="sales_price"/>
                </xpath>

                <xpath expr="/form/sheet/notebook/page[@id='aml_tab']/field[@name='line_ids']/list//field[@name='discount_amount_currency']" position="before">
                    <field name="price_list_id" readonly="1" optional="hide"/>
                </xpath>
                <!--                <xpath expr="//form[1]/sheet[1]/notebook[1]/page[@name='aml_tab']/field[@name='line_ids']/tree[1]/field[@name='discount_amount_currency']"-->
                <!-- position="before">-->
                <!--                    <field name="price_list_id" optional="hide"/>-->
                <!--                </xpath>-->

                <xpath expr="//button[@name='action_reverse']" position="attributes">
                    <attribute name="context">
                        {'credit_note': True}
                    </attribute>
                </xpath>
                <xpath expr="//button[@name='button_draft']" position="attributes">
                    <attribute name="confirm">
                        Invoice will be set to Draft , make sure to Return Delivery.
                    </attribute>
                </xpath>
                <xpath expr="//field[@name='payment_reference']" position="replace"/>
                <xpath expr="//field[@name='partner_shipping_id']" position="before">
                    <field invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt')" name="payment_reference"/>
                    <!--                    <field invisible="1" name="invoice_from_sale"/>-->
                </xpath>
                <xpath expr="//form[1]/sheet[1]/group[1]/group[1]/label[1]" position="before">
                    <field name="parent_company_id"/>
                </xpath>
                <xpath expr="/form/sheet/notebook/page[@id='aml_tab']/field[@name='line_ids']/list//field[@name='account_id']" position="after">
                    <field name="product_id" options="{'no_create': true, 'no_open': true}" optional="hide"/>
                </xpath>
            </field>
        </record>

