<odoo>
    <record id="view_res_config_settings_custom_pred" model="ir.ui.view">
        <field name="name">res.config.settings.custom.pred</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='account_vendor_bills']" position="inside">
                <setting string="Predict vendor bill account" help="The system will try to predict the account on vendor bill lines based on the label of the line">
                    <field name="enable_custom_feature"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
