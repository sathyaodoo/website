<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_sale_order_form_driver_inherit" model="ir.ui.view">
            <field name="name">sale.order.form.driver.inherit</field>
            <field name="model">sale.order</field>
            <field name="priority">17</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='commitment_date']" position="after">
                    <field name="driver_id"/>
                </xpath>
            </field>
        </record>

        <record id="view_sale_order_search_driver_inherit" model="ir.ui.view">
            <field name="name">sale.order.search.driver.inherit</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_sales_order_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search/field[@name='name']" position="after">
                    <field name="driver_id" string="Driver"/>
                </xpath>
                <xpath expr="//filter[@name='salesperson']" position="after">
                    <filter string="Driver" name="groupby_urgency" domain="[]"
                            context="{'group_by':'driver_id'}"/>
                </xpath>
            </field>
        </record>


        <record id="view_account_move_list_driver_inherit" model="ir.ui.view">
            <field name="name">account_move_list_driver_inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_out_invoice_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_date_due']" position="after">
                 <field name="driver_id" invisible="move_type != 'out_invoice'"/>
                </xpath>
            </field>
        </record>

        <record id="view_account_move_search_driver_inherit" model="ir.ui.view">
            <field name="name">account.move.search.driver.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_invoice_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//search/field[@name='name']" position="after">
                    <field name="driver_id" string="Driver"/>
                </xpath>
                <xpath expr="//filter[@name='status']" position="after">
                    <filter string="Driver" name="groupby_driver" domain="[]"
                            context="{'group_by':'driver_id'}"/>
                </xpath>
            </field>
        </record>
        <record id="view_order_form_custom_inherit_erpc" model="ir.ui.view">
            <field name="name">sale.order.form.custom.erpc</field>
            <field name="model">sale.order</field>
            <field name="priority">25</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <data>
                    
                    <xpath expr="//field[@name='parent_id']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath>
                    
                    <xpath expr="//field[@name='partner_invoice_id']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath>
                    <xpath expr="//field[@name='partner_shipping_id']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath>
                    <xpath expr="//field[@name='driver_id']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath>
                </data>
            </field>
        </record>
        <record id="view_accounting_form_custom_erpc" model="ir.ui.view">
            <field name="name">account.move.form.custom.erpc</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//field[@name='bank_partner_id']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath>
                    
                    <!-- <xpath expr="//field[@name='collector']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath> -->
                    <xpath expr="//field[@name='commercial_partner_id']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath>
<!--                    <xpath expr="//field[@name='driver_id']" position="attributes">-->
<!--                        <attribute name="options">{'no_create': True}</attribute>-->
<!--                    </xpath>-->
                    <xpath expr="//field[@name='parent_company_id']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath>
                    <xpath expr="//field[@name='partner_id']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath>
                    <xpath expr="//field[@name='partner_shipping_id']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath>
                </data>
            </field>
        </record>
        <record id="view_transfers_form_custom_erpc" model="ir.ui.view">
            <field name="name">stock.picking.form.custom.erpc</field>
            <field name="model">stock.picking</field>
            <field name="inherit_id" ref="stock.view_picking_form"/>
            <field name="arch" type="xml">
                <data>
                    <!-- <xpath expr="//field[@name='collector']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath> -->
                    
                    <xpath expr="//field[@name='driver_id']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath>
                    
                    <xpath expr="//field[@name='owner_id']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath>
                    <xpath expr="//field[@name='parent_company_id']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath>
                    <xpath expr="//field[@name='partner_id']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath>
                </data>
            </field>
        </record>
        <record id="view_purchase_form_custom_erpc" model="ir.ui.view">
            <field name="name">purchase.order.form.custom.erpc</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <data>
                    <xpath expr="//field[@name='dest_address_id']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath>
                    
                    
                    <xpath expr="//field[@name='partner_id']" position="attributes">
                        <attribute name="options">{'no_create': True}</attribute>
                    </xpath>
                
                </data>
            </field>
        </record>
    </data>
</odoo>
