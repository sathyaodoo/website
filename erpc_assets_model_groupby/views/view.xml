<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_account_move_line_group_by_inherit_asset_model" model="ir.ui.view">
        <field name="name">account.move.line.group.by.inherit.asset.model</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_account_move_line_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/group/filter[@name='group_by_account']" position="after">
                <filter name="asset_model_id" string="Asset Model" context="{'group_by': 'asset_model_id'}"/>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="asset_model_id" string="Asset Model"/>
            </xpath>

        </field>
    </record>

    <record id="view_account_move_line_list_inherit_asset_model" model="ir.ui.view">
        <field name="name">account.move.line.list.inherit.asset.model</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='account_id']" position="after">
                <field name="asset_model_id" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>