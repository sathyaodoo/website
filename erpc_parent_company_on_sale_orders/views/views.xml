        <record id="view_account_invoice_tree_inherit_erpc" model="ir.ui.view">
            <field name="name">account.move.tree.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_out_invoice_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='invoice_date']" position="after">
                    <field name="parent_company_id"/>
                </xpath>
            </field>
        </record>
        <record id="view_account_invoice_search_inherit_erpc" model="ir.ui.view">
            <field name="name">account.move.search.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_account_invoice_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//group/filter[@name='salesperson']" position="after">
                    <filter string="Parent Company" name="groupby_parent_company_id" domain="[]"
                            context="{'group_by':'parent_company_id'}"/>
                </xpath>
            </field>
        </record>
