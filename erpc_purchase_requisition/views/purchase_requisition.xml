<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record id="view_requisition_po_line" model="ir.ui.view">

            <field name="name">view_requisition_po_line</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//list/field[@name='product_id']" position="before">
                    <field name='related_requisition_line_id' readonly='0' optional='show'/>
                    <field name='related_requisition_line_name' readonly='1' optional='show'/>
                </xpath>
            </field>
        </record>

        <record id="view_requisition_id_inh" model="ir.ui.view">
            <field name="name">view_requisition_id_inh</field>
            <field name="model">purchase.requisition</field>
            <field name="inherit_id" ref="purchase_requisition.view_purchase_requisition_form"/>
            <field name="arch" type="xml">
               
                <!-- <xpath expr="//field[@name='schedule_date']" position="after">
                    <field name='total_quantities'/>
                    <field name='total_amount'/>
                </xpath> -->

                <xpath expr="//list/field[@name='qty_ordered']" position="after">
                    <field name='extra_ordered_quantity' optional='show'/>
                    <field name='remaining_ordered_quantity' optional='show'/>
                </xpath>
            </field>
        </record>

        <record id="view_requisition_id_inh_tree" model="ir.ui.view">
            <field name="name">view_requisition_id_inh_tree</field>
            <field name="model">purchase.requisition</field>
            <field name="inherit_id" ref="purchase_requisition.view_purchase_requisition_tree"/>
            <field name="arch" type="xml">

                <xpath expr="//field[@name='state']" position="before">
                    <field name='total_quantities'/>
                    <field name='total_amount'/>
                    <field name='remaining_ordered_quantity'/>

                </xpath>

            </field>
        </record>

        <record id="view_wizard_requisition_line" model="ir.ui.view">
            <field name="name">view.requisition.line.wizard.tree</field>
            <field name="model">purchase.requisition.line</field>
            <field name="arch" type="xml">
                <list string="Purchase Requisition Line">
                    <header>
                        <button name='create_purchase_order_for_selected_lines' string='Create PO' class='btn-primary' type='object'/>
                    </header>
                    <field name="product_id" on_change="1" required="True"/>
                    <field name="requisition_id" optional="show"/>
                    <field name="product_qty" optional="show"/>
                    <field name="qty_ordered" optional="show"/>
                    <field name="price_unit" optional="show"/>
                    <field name="vendor_id" optional="show"/>
                    <field name="origin" optional="show"/>
                    <field name="extra_ordered_quantity" optional="hide" string='BO Qty'/>
                    <field name="remaining_ordered_quantity" optional='hide'/>
                </list>
            </field>
        </record>

        <record id="act_purchase_requisition_line" model="ir.actions.act_window">
            <field name="name">Purchase Requisition Line</field>
            <field name="res_model">purchase.requisition.line</field>
            <field name="view_mode">list,form</field>
        </record>

<!--        <menuitem action="act_purchase_requisition_line"-->
<!--          id="act_purchase_requisition_line_menu" parent="purchase.menu_procurement_management"-->
<!--          sequence="100"/>-->
        

    </data>
</odoo>