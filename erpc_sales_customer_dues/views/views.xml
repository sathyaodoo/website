<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Tree view definition for mirror journal items -->
        <record id="mirror_journal_items" model="ir.ui.view">
            <field name="name">mirror.journal.items</field>
            <field name="model">account.move.line</field>
            <field name="arch" type="xml">
                <list>
                    <field name="move_name" string="Journal Entry" widget="open_move_widget"/>
                    <field name="amount_residual" readonly="1" sum="Total"/>
                    <field name="company_currency_id" column_invisible="True"/>
 
                </list>
            </field>
        </record>
        
        <!-- Access rights definition -->
        <record id="account_root_access_right_customer_dues" model="ir.model.access">
            <field name="name">account.root</field>
            <field name="model_id" ref='account.model_account_root'/>
            <field name="group_id" ref='sales_team.group_sale_salesman'/>
            <field name="perm_read" eval='True'/>
            <field name="perm_write" eval='False'/>
            <field name="perm_create" eval='False'/>
            <field name="perm_unlink" eval='False'/>
        </record>

        <!-- Action window for admin users -->
        <record id="mirror_journal_items_action_for_admin" model="ir.actions.act_window">
            <field name="name">Journal Items</field>
            <field name="res_model">account.move.line</field>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="erpc_sales_customer_dues.mirror_journal_items"/>
            <field name="domain">[('parent_state', '=', 'posted'), ('account_id.account_type', '=', 'asset_receivable'), ('account_id.non_trade', '=', False), ('amount_residual', '!=', 0)]</field>
            <field name="context">{'group_by': ['x_studio_parent_company_1', 'partner_id']}</field>
        </record>
        
        <!-- Action window for regular salesmen -->
        <record id="mirror_journal_items_action" model="ir.actions.act_window">
            <field name="name">Journal Items</field>
            <field name="res_model">account.move.line</field>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="erpc_sales_customer_dues.mirror_journal_items"/>
            <field name="domain">[('parent_state', '=', 'posted'), ('account_id.account_type', '=', 'asset_receivable'), ('account_id.non_trade', '=', False), ('amount_residual', '!=', 0), ('partner_id.user_id', '=', uid)]</field>
            <field name="context">{'group_by': ['x_studio_parent_company_1', 'partner_id']}</field>
        </record>

        <!-- Menu item for admin users -->
        <menuitem id="menu_journal_item_mirror_view_for_admin" name="Customer Due's Admin" 
            action="mirror_journal_items_action_for_admin"
            parent="sale.sale_menu_root" 
            groups="sales_team.group_sale_salesman_all_leads"/>
            
        <!-- Menu item for regular salesmen (NOT visible for admins) -->
        <menuitem id="menu_journal_item_mirror_view" name="Customer Due's" 
            action="mirror_journal_items_action"
            parent="sale.sale_menu_root" 
            groups="sales_team.group_sale_salesman"/>

    </data>
</odoo>
