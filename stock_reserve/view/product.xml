<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_reservation_button" model="ir.ui.view">
        <field name="name">product.template.reservation.button</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_inline oe_stat_button" icon="fa-lock" invisible="type != 'product'" name="action_view_reservations" type="object">
                    <field name="reservation_count" string="Stock Reservations" widget="statinfo"/>
                </button>
            </xpath></field>
    </record>
    <record id="product_product_form_view_reservation_button" model="ir.ui.view">
        <field name="name">product.product.reservation.button</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_inline oe_stat_button" icon="fa-lock" invisible="type != 'product'" name="action_view_reservations" type="object">
                    <field name="reservation_count" string="Stock Reservations" widget="statinfo"/>
                </button>
            </xpath></field>
    </record>
</odoo>
