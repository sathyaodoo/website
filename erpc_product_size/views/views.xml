        <record id="view_approval_request_form_inherit" model="ir.ui.view">
            <field name="name">approval.request.view.form.inherit</field>
            <field name="model">approval.request</field>
            <field name="inherit_id" ref="approvals.approval_request_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='date_confirmed']" position="after">
                    <field name="productLines" widget="many2many_tags" options="{'no_create': True}" invisible="1"/>
                </xpath>

                <xpath expr="//field[@name='amount']" position="replace">
                    <field name="amount_char" invisible="has_amount == 'no'" readonly="request_status != 'new'"/>

                </xpath>


                 <xpath expr="//button[@name='action_open_purchase_orders']" position="replace">

            <button name="action_open_purchase_orders" type="object"
                    class="oe_stat_button" icon="fa-credit-card"
                    invisible="purchase_order_count == 0" groups="purchase.group_purchase_user">
                    <field name="purchase_order_count" string="Purchase Orders" widget="statinfo"/>
                </button>
                </xpath>
            </field>
        </record>


        <record model="ir.model.access" id="access_internal_user_purchase_order_line">
            <field name="name">access_internal_user_purchase_order_line</field>
            <field name="model_id" ref="purchase.model_purchase_order_line"/>
            <field name="group_id" ref="base.group_user"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">0</field>
            <field name="perm_unlink">0</field>
        </record>




        <record id="approval_request_view_tree_inherit" model="ir.ui.view">
            <field name="name">approval.request.view.tree.inherit</field>
            <field name="model">approval.request</field>
            <field name="inherit_id" ref="approvals.approval_request_view_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//list" position="inside">
                    <field name="productLines" widget="many2many_tags" options="{'no_create': True}"/>
                    <field name="amount_char"/>
                </xpath>
            </field>
        </record>


