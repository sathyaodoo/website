<odoo>
    <data>
        <record id="erpc_product_normal_form_view" model="ir.ui.view">
            <field name="name">erpc.product.product.form</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="product.product_normal_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='uom_id']" position="after">
                    <field name="available_quant_location_1"/>
                    <field name="available_quant_location_2"/>
                </xpath>
            </field>
        </record>

        <record id="erpc_view_stock_product_tree" model="ir.ui.view">
            <field name="name">erpc.product.stock.tree.inherit</field>
            <field name="model">product.product</field>
            <field name="inherit_id" ref="stock.view_stock_product_tree"/>
            <field name="arch" type="xml">
                <xpath expr="/list//field[@name='qty_available']" position="after">
                    <field name="available_quant_location_1"/>
                    <field name="available_quant_location_2"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
