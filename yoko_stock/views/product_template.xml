        <record id="erpc_yoko_stock_view_stock_product_template_tree" model="ir.ui.view">
            <field name="name">erpc.product.template.stock.tree.inherit</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="stock.view_stock_product_template_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='qty_available']" position="after">
                    <field name="incoming_qty" optional="show"/>
<!--                    <field name="erpc_free_qty" invisible="1"/>-->
                </xpath>
            </field>
        </record>
