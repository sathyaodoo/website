<odoo>

    <record id="view_account_financial_group_tree" model="ir.ui.view">
        <field name="name">account.financial.group.tree</field>
        <field name="model">account.financial.group</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="type"/>
                <field name="company_id"/>
            </list>
        </field>
    </record>

    <record id="view_account_financial_group_form" model="ir.ui.view">
        <field name="name">account.financial.group.form</field>
        <field name="model">account.financial.group</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="type"/>
                        <field name="company_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_account_list_inherit" model="ir.ui.view">
        <field name="name">account.account.list.inherit</field>
        <field name="model">account.account</field>
        <field name="inherit_id" ref="account.view_account_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='group_id']" position="after">
                <field name="financial_group_id" optional="hide"/>
                <field name="financial_type" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_form_inherit_financial_group" model="ir.ui.view">
        <field name="name">account.account.form.inherit.financial.group</field>
        <field name="model">account.account</field>
        <field name="inherit_id" ref="account.view_account_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='group_id']" position="after">
                <field name="financial_group_id"/>
                <field name="financial_type"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_move_line_list_inherit_financial_group" model="ir.ui.view">
        <field name="name">account.move.line.list.inherit.financial.group</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='account_id']" position="after">
                <field name="financial_group_id" optional="hide"/>
                <field name="financial_type" optional="hide"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_analytic_line_list_inherit_financial_group" model="ir.ui.view">
        <field name="name">account.analytic.line.list.inherit.financial.group</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="analytic.view_account_analytic_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='general_account_id']" position="after">
                <field name="financial_group_id" optional="show"/>
                <field name="financial_type" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_move_line_group_by_inherit_financial_groups" model="ir.ui.view">
        <field name="name">account.move.line.group.by.inherit.financial.groups</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_account_move_line_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search/group/filter[@name='group_by_account']" position="after">
                <filter name="financial_group_id" string="Financial Group" context="{'group_by': 'financial_group_id'}"/>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="financial_group_id" string="Financial Group"/>
            </xpath>
        </field>
    </record>

    <record id="view_account_analytic_line_group_by_inherit_financial_groups" model="ir.ui.view">
        <field name="name">account.analytic.line.group.by.inherit.financial.groups</field>
        <field name="model">account.analytic.line</field>
        <field name="inherit_id" ref="account.view_account_analytic_line_filter_inherit_account"/>
        <field name="arch" type="xml">
            <xpath expr="//search/group/filter[@name='group_by_financial_account']" position="after">
                <filter name="financial_group_id" string="Financial Group" context="{'group_by': 'financial_group_id'}"/>
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="financial_group_id" string="Financial Group"/>
            </xpath>
        </field>
    </record>

    <record id="action_financial_groups" model="ir.actions.act_window">
        <field name="name">Financial Groups</field>
        <field name="res_model">account.financial.group</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_financial_groups"
              name="Financial Groups"
              parent="account.account_account_menu"
              action="action_financial_groups"
              sequence="120"/>
</odoo>
