<odoo>
    <data>
        <record id="account_analytic_plan_tree_inherit_edits" model="ir.ui.view">
            <field name="name">account.analytic.plan.tree.inherit</field>
            <field name="model">account.analytic.plan</field>
            <field name="inherit_id" ref="analytic.account_analytic_plan_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='color']" position="after">
                    <field name="include_stock_entry"/>
                </xpath>
            </field>
        </record>
        <record id="account_invoice_tree_inherit_edits" model="ir.ui.view">
            <field name="name">account.invoice.tree.inherit</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form[1]/sheet[1]/div[not(@name)][1]/h1[1]/field[@name='name']" position="attributes">
                    <attribute name="readonly">True</attribute>
                </xpath>
            </field>
        </record>
        <record id="view_order_form_inhderit" model="ir.ui.view">
            <field name="name">sale.order.form.inherit</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="restrict_buttons" invisible="1"/>
                </xpath>
                <xpath expr="//button[@name='action_cancel']" position="attributes">
                    <attribute name="invisible">state not in ["draft", "sent", "sale"] or not id or locked or restrict_buttons == True</attribute>
                </xpath>
                <xpath expr="//button[@name='action_draft']" position="attributes">
                    <attribute name="invisible">state != "cancel" and restrict_buttons == True</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
