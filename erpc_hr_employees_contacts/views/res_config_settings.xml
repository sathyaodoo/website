<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="erpc_account_res_config_settings_view_form_inherit_foreign_purchase" model="ir.ui.view">
        <field name="name">erpc.account.res.config.settings.foreign.purchase</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='default_accounts']" position="inside">
                <setting string="Company Accounts:">
                    <div class="content-group">

                        <div class="row mt8">
                            <label for="company_receivable_account_id"
                                   class="col-lg-5 o_light_label"/>
                            <field name="company_receivable_account_id"/>
                        </div>
                        <div class="row mt8">
                            <label for="company_payable_account_id"
                                   class="col-lg-5 o_light_label"/>
                            <field name="company_payable_account_id"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>